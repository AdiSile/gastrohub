# ============================================================
# GastroHub - Configurare variabile de mediu
# ============================================================
# Copiază acest fișier ca .env și completează valorile.
# NU commita .env în git!

# -------------------------------
# Server
# -------------------------------
PORT=3000
NODE_ENV=development

# -------------------------------
# JWT (JSON Web Token)
# -------------------------------
JWT_SECRET=schimba_cu_un_secret_puternic_aici
JWT_EXPIRES_IN=7d

# -------------------------------
# Cookie
# -------------------------------
COOKIE_SECRET=schimba_cu_un_secret_puternic_pentru_cookie

# -------------------------------
# Super Admin (seed automat)
# -------------------------------
SUPER_ADMIN_EMAIL=super_admin@gastrohub.io
SUPER_ADMIN_PASSWORD=admin123

# -------------------------------
# CORS
# -------------------------------
CORS_ORIGIN=http://localhost:4200

# -------------------------------
# NeDB (bază de date embedded)
# -------------------------------
# Directorul implicit de stocare este `./data/`.
# Poți suprascrie calea aici:
# DB_PATH=./data