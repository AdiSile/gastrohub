<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= locals.title || 'Înregistrare' %> – GastroHub</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <style>
    /* ============================================================
       RESET & BASE
       ============================================================ */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --purple-900: #1a0533;
      --purple-800: #2d0a4e;
      --purple-700: #3f0e6b;
      --purple-600: #5b1a99;
      --purple-500: #7b2dcc;
      --purple-400: #9b59e6;
      --purple-300: #c39bff;
      --purple-200: #ddc4ff;
      --surface-glass: rgba(255, 255, 255, 0.08);
      --surface-glass-hover: rgba(255, 255, 255, 0.13);
      --border-glass: rgba(255, 255, 255, 0.14);
      --text-primary: #f0e6ff;
      --text-secondary: #bfa5e0;
      --text-muted: #8b73ad;
      --input-bg: rgba(255, 255, 255, 0.07);
      --input-border: rgba(255, 255, 255, 0.15);
      --input-focus: #9b59e6;
      --btn-primary: #7b2dcc;
      --btn-primary-hover: #8b40e0;
      --btn-primary-active: #6a1fb8;
      --error-color: #ff6b8a;
      --success-color: #4cd9a7;
      --warning-color: #ffb347;
      --radius-sm: 8px;
      --radius-md: 14px;
      --radius-lg: 20px;
      --transition: 0.25s ease;
    }

    html {
      font-size: 16px;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #0d0221 0%, #1a0533 25%, #2d0a4e 50%, #1a0533 75%, #0d0221 100%);
      background-attachment: fixed;
      color: var(--text-primary);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      line-height: 1.6;
      position: relative;
      overflow-x: hidden;
    }

    /* ============================================================
       ANIMATED BACKGROUND PARTICLES
       ============================================================ */
    .bg-particles {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .bg-particle {
      position: absolute;
      border-radius: 50%;
      background: var(--purple-400);
      opacity: 0.08;
      animation: floatParticle linear infinite;
    }

    @keyframes floatParticle {
      0% {
        transform: translateY(0) translateX(0) scale(1);
        opacity: 0.03;
      }
      25% {
        opacity: 0.08;
      }
      50% {
        transform: translateY(-120px) translateX(40px) scale(1.4);
        opacity: 0.06;
      }
      75% {
        opacity: 0.03;
      }
      100% {
        transform: translateY(0) translateX(0) scale(1);
        opacity: 0.03;
      }
    }

    /* ============================================================
       GLOW ORBS
       ============================================================ */
    .glow-orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.18;
      pointer-events: none;
      z-index: 0;
      animation: pulseOrb 8s ease-in-out infinite;
    }

    .glow-orb--top-right {
      width: 420px;
      height: 420px;
      background: var(--purple-500);
      top: -120px;
      right: -100px;
      animation-delay: 0s;
    }

    .glow-orb--bottom-left {
      width: 350px;
      height: 350px;
      background: #3c1a70;
      bottom: -100px;
      left: -80px;
      animation-delay: -4s;
    }

    .glow-orb--center {
      width: 280px;
      height: 280px;
      background: var(--purple-600);
      top: 55%;
      left: 55%;
      transform: translate(-50%, -50%);
      opacity: 0.1;
      animation-delay: -2s;
    }

    @keyframes pulseOrb {
      0%, 100% { transform: scale(1); opacity: 0.16; }
      50% { transform: scale(1.2); opacity: 0.24; }
    }

    /* ============================================================
       REGISTER CONTAINER
       ============================================================ */
    .register-wrapper {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 480px;
    }

    /* Logo / Brand */
    .register-brand {
      text-align: center;
      margin-bottom: 28px;
    }

    .register-brand .brand-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 64px;
      height: 64px;
      border-radius: var(--radius-md);
      background: linear-gradient(135deg, var(--purple-500), var(--purple-600));
      font-size: 28px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 12px;
      box-shadow: 0 8px 32px rgba(123, 45, 204, 0.35);
    }

    .register-brand .brand-name {
      font-size: 24px;
      font-weight: 700;
      letter-spacing: 0.5px;
      color: #fff;
    }

    .register-brand .brand-sub {
      font-size: 13px;
      color: var(--text-secondary);
      font-weight: 400;
      margin-top: 2px;
    }

    /* ============================================================
       GLASS CARD
       ============================================================ */
    .glass-card {
      background: var(--surface-glass);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid var(--border-glass);
      border-radius: var(--radius-lg);
      padding: 36px 32px;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.06);
      transition: border-color var(--transition);
    }

    .glass-card:hover {
      border-color: rgba(255, 255, 255, 0.22);
    }

    .glass-card .card-header {
      text-align: center;
      margin-bottom: 24px;
    }

    .glass-card .card-header h2 {
      font-size: 22px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 6px;
    }

    .glass-card .card-header p {
      font-size: 14px;
      color: var(--text-secondary);
    }

    /* ============================================================
       FORM STYLES
       ============================================================ */
    .form-group {
      margin-bottom: 18px;
    }

    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 7px;
      letter-spacing: 0.3px;
    }

    .form-group .input-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }

    .form-group .input-wrapper i {
      position: absolute;
      left: 14px;
      font-size: 15px;
      color: var(--text-muted);
      pointer-events: none;
      transition: color var(--transition);
      z-index: 1;
    }

    .form-group input {
      width: 100%;
      padding: 12px 14px 12px 42px;
      font-size: 14px;
      font-family: 'Inter', sans-serif;
      color: #fff;
      background: var(--input-bg);
      border: 1px solid var(--input-border);
      border-radius: var(--radius-sm);
      outline: none;
      transition: all var(--transition);
    }

    .form-group input::placeholder {
      color: var(--text-muted);
      opacity: 0.7;
    }

    .form-group input:focus {
      border-color: var(--input-focus);
      background: rgba(255, 255, 255, 0.1);
      box-shadow: 0 0 0 4px rgba(155, 89, 230, 0.15);
    }

    .form-group .input-wrapper:focus-within i {
      color: var(--purple-300);
    }

    .form-group .form-error {
      font-size: 12px;
      color: var(--error-color);
      margin-top: 5px;
      display: none;
      align-items: center;
      gap: 5px;
    }

    .form-group .form-error.show {
      display: flex;
    }

    .form-group .form-hint {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 5px;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    /* Form-level generic error alert (populated by client-side fetch) */
    .form-alert {
      padding: 12px 16px;
      border-radius: var(--radius-sm);
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 20px;
      display: none;
      align-items: center;
      gap: 10px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      background: rgba(255, 107, 138, 0.15);
      border: 1px solid rgba(255, 107, 138, 0.3);
      color: #ffb3c3;
    }

    .form-alert.show {
      display: flex;
    }

    /* Password toggle */
    .password-toggle {
      position: absolute;
      right: 12px;
      background: none;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      font-size: 15px;
      padding: 4px;
      line-height: 1;
      transition: color var(--transition);
      z-index: 2;
    }

    .password-toggle:hover {
      color: var(--purple-300);
    }

    /* Password strength meter */
    .password-strength {
      display: flex;
      gap: 4px;
      margin-top: 8px;
    }

    .password-strength .strength-bar {
      height: 4px;
      flex: 1;
      border-radius: 2px;
      background: rgba(255, 255, 255, 0.1);
      transition: background var(--transition);
    }

    .strength-bar.weak    { background: var(--error-color); }
    .strength-bar.medium  { background: var(--warning-color); }
    .strength-bar.strong  { background: var(--success-color); }

    .strength-text {
      font-size: 11px;
      margin-top: 4px;
      font-weight: 500;
    }

    .strength-text.weak   { color: var(--error-color); }
    .strength-text.medium { color: var(--warning-color); }
    .strength-text.strong { color: var(--success-color); }

    /* ============================================================
       TERMS CHECKBOX
       ============================================================ */
    .form-options {
      margin-bottom: 22px;
    }

    .terms-check {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      cursor: pointer;
      color: var(--text-secondary);
      user-select: none;
      font-size: 13px;
      line-height: 1.5;
    }

    .terms-check input[type="checkbox"] {
      display: none;
    }

    .terms-check .checkmark {
      width: 20px;
      height: 20px;
      border-radius: 4px;
      border: 2px solid var(--input-border);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all var(--transition);
      flex-shrink: 0;
      margin-top: 1px;
    }

    .terms-check .checkmark i {
      font-size: 10px;
      color: #fff;
      opacity: 0;
      transition: opacity var(--transition);
    }

    .terms-check input:checked + .checkmark {
      background: var(--purple-500);
      border-color: var(--purple-500);
    }

    .terms-check input:checked + .checkmark i {
      opacity: 1;
    }

    .terms-check a {
      color: var(--purple-300);
      text-decoration: none;
      font-weight: 500;
    }

    .terms-check a:hover {
      text-decoration: underline;
    }

    .terms-error {
      font-size: 12px;
      color: var(--error-color);
      margin-top: 6px;
      margin-left: 30px;
      display: none;
      align-items: center;
      gap: 5px;
    }

    .terms-error.show {
      display: flex;
    }

    /* ============================================================
       SUBMIT BUTTON
       ============================================================ */
    .btn-submit {
      width: 100%;
      padding: 13px 24px;
      font-size: 15px;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      color: #fff;
      background: linear-gradient(135deg, var(--purple-500), var(--purple-600));
      border: none;
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: all var(--transition);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      box-shadow: 0 4px 18px rgba(123, 45, 204, 0.35);
    }

    .btn-submit:hover {
      background: linear-gradient(135deg, var(--btn-primary-hover), var(--purple-500));
      box-shadow: 0 6px 24px rgba(123, 45, 204, 0.5);
      transform: translateY(-1px);
    }

    .btn-submit:active {
      transform: translateY(0);
      box-shadow: 0 2px 10px rgba(123, 45, 204, 0.3);
    }

    .btn-submit:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
      box-shadow: 0 2px 8px rgba(123, 45, 204, 0.2);
    }

    .btn-submit .spinner-btn {
      width: 18px;
      height: 18px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      display: none;
    }

    .btn-submit.loading .spinner-btn {
      display: block;
    }

    .btn-submit.loading .btn-text {
      display: none;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* ============================================================
       SEPARATOR
       ============================================================ */
    .separator {
      display: flex;
      align-items: center;
      gap: 14px;
      margin: 22px 0;
    }

    .separator::before,
    .separator::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border-glass);
    }

    .separator span {
      font-size: 12px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 500;
    }

    /* ============================================================
       LOGIN LINK
       ============================================================ */
    .login-link {
      text-align: center;
      font-size: 14px;
      color: var(--text-secondary);
    }

    .login-link a {
      color: var(--purple-300);
      text-decoration: none;
      font-weight: 600;
      transition: color var(--transition);
    }

    .login-link a:hover {
      color: var(--purple-200);
      text-decoration: underline;
    }

    /* ============================================================
       ALERT / TOAST
       ============================================================ */
    .alert {
      padding: 12px 16px;
      border-radius: var(--radius-sm);
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    .alert-error {
      background: rgba(255, 107, 138, 0.15);
      border: 1px solid rgba(255, 107, 138, 0.3);
      color: #ffb3c3;
    }

    .alert-success {
      background: rgba(76, 217, 167, 0.12);
      border: 1px solid rgba(76, 217, 167, 0.3);
      color: #7be8c4;
    }

    .alert-info {
      background: rgba(155, 89, 230, 0.12);
      border: 1px solid rgba(155, 89, 230, 0.3);
      color: #c39bff;
    }

    .alert-warning {
      background: rgba(255, 179, 71, 0.12);
      border: 1px solid rgba(255, 179, 71, 0.3);
      color: #ffcc80;
    }

    /* ============================================================
       INLINE FIELD ROW (for two columns on wider screens)
       ============================================================ */
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    @media (max-width: 420px) {
      .form-row {
        grid-template-columns: 1fr;
      }
    }

    /* ============================================================
       FOOTER
       ============================================================ */
    .register-footer {
      text-align: center;
      margin-top: 24px;
      font-size: 12px;
      color: var(--text-muted);
    }

    .register-footer span {
      opacity: 0.6;
    }

    /* ============================================================
       RESPONSIVE
       ============================================================ */
    @media (max-width: 480px) {
      body {
        padding: 16px;
        align-items: flex-start;
        padding-top: 48px;
      }

      .glass-card {
        padding: 24px 20px;
        border-radius: var(--radius-md);
      }

      .glass-card .card-header h2 {
        font-size: 20px;
      }

      .register-brand .brand-icon {
        width: 52px;
        height: 52px;
        font-size: 24px;
      }

      .register-brand .brand-name {
        font-size: 20px;
      }
    }

    @media (max-width: 360px) {
      .glass-card {
        padding: 20px 16px;
      }
    }
  </style>
</head>
<body>
  <!-- ============================================================
       BACKGROUND EFFECTS
       ============================================================ -->
  <div class="bg-particles" id="bgParticles"></div>

  <div class="glow-orb glow-orb--top-right"></div>
  <div class="glow-orb glow-orb--bottom-left"></div>
  <div class="glow-orb glow-orb--center"></div>

  <!-- ============================================================
       REGISTER WRAPPER
       ============================================================ -->
  <div class="register-wrapper">
    <!-- Brand -->
    <div class="register-brand">
      <div class="brand-icon">GH</div>
      <div class="brand-name">GastroHub</div>
      <div class="brand-sub">Creează-ți contul tău</div>
    </div>

    <!-- Glass Card -->
    <div class="glass-card">
      <div class="card-header">
        <h2><i class="fas fa-user-plus" style="margin-right: 8px;"></i>Înregistrare</h2>
        <p>Completează datele de mai jos pentru a-ți crea contul de client.</p>
      </div>

      <!-- Flash Messages -->
      <% if (locals.flash && flash.message) { %>
        <div class="alert alert-<%= flash.type || 'info' %>">
          <i class="fas fa-<%= flash.type === 'success' ? 'check-circle' : flash.type === 'error' ? 'exclamation-circle' : 'info-circle' %>"></i>
          <%= flash.message %>
        </div>
      <% } %>

      <!-- Server Error -->
      <% if (locals.error && error) { %>
        <div class="alert alert-error">
          <i class="fas fa-exclamation-triangle"></i>
          <%= typeof error === 'string' ? error : (error.message || 'Eroare la înregistrare') %>
        </div>
      <% } %>

      <!-- Generic form alert (populated by client-side fetch errors) -->
      <div class="form-alert" id="formAlert">
        <i class="fas fa-exclamation-circle"></i>
        <span id="formAlertText"></span>
      </div>

      <!-- Register Form -->
      <form id="registerForm" action="/api/auth/register" method="POST" novalidate>
        <!-- Nume și Prenume - pe același rând -->
        <div class="form-row">
          <!-- Prenume -->
          <div class="form-group">
            <label for="prenume">Prenume</label>
            <div class="input-wrapper">
              <i class="fas fa-user"></i>
              <input
                type="text"
                id="prenume"
                name="prenume"
                placeholder="Prenumele tău"
                value="<%= locals.prenume || '' %>"
                autocomplete="given-name"
                required
              />
            </div>
            <div class="form-error" id="prenumeError">
              <i class="fas fa-exclamation-circle"></i>
              <span id="prenumeErrorText"></span>
            </div>
          </div>

          <!-- Nume -->
          <div class="form-group">
            <label for="nume">Nume</label>
            <div class="input-wrapper">
              <i class="fas fa-user"></i>
              <input
                type="text"
                id="nume"
                name="nume"
                placeholder="Numele tău"
                value="<%= locals.nume || '' %>"
                autocomplete="family-name"
                required
              />
            </div>
            <div class="form-error" id="numeError">
              <i class="fas fa-exclamation-circle"></i>
              <span id="numeErrorText"></span>
            </div>
          </div>
        </div>

        <!-- Email -->
        <div class="form-group">
          <label for="email">Adresă de email</label>
          <div class="input-wrapper">
            <i class="fas fa-envelope"></i>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="nume@exemplu.com"
              value="<%= locals.email || '' %>"
              autocomplete="email"
              required
            />
          </div>
          <div class="form-error" id="emailError">
            <i class="fas fa-exclamation-circle"></i>
            <span id="emailErrorText"></span>
          </div>
        </div>

        <!-- Telefon -->
        <div class="form-group">
          <label for="telefon">Telefon <span style="font-weight:400;color:var(--text-muted);">(opțional)</span></label>
          <div class="input-wrapper">
            <i class="fas fa-phone"></i>
            <input
              type="tel"
              id="telefon"
              name="telefon"
              placeholder="07xx xxx xxx"
              value="<%= locals.telefon || '' %>"
              autocomplete="tel"
            />
          </div>
          <div class="form-error" id="telefonError">
            <i class="fas fa-exclamation-circle"></i>
            <span id="telefonErrorText"></span>
          </div>
        </div>

        <!-- Parolă -->
        <div class="form-group">
          <label for="password">Parolă</label>
          <div class="input-wrapper">
            <i class="fas fa-lock"></i>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Minim 6 caractere"
              autocomplete="new-password"
              required
              minlength="6"
            />
            <button type="button" class="password-toggle" id="passwordToggle" tabindex="-1" aria-label="Arată/ascunde parola">
              <i class="fas fa-eye"></i>
            </button>
          </div>
          <!-- Password strength indicator -->
          <div class="password-strength" id="passwordStrength">
            <div class="strength-bar" id="bar1"></div>
            <div class="strength-bar" id="bar2"></div>
            <div class="strength-bar" id="bar3"></div>
            <div class="strength-bar" id="bar4"></div>
          </div>
          <div class="strength-text" id="strengthText"></div>
          <div class="form-error" id="passwordError">
            <i class="fas fa-exclamation-circle"></i>
            <span id="passwordErrorText"></span>
          </div>
        </div>

        <!-- Confirmă Parola -->
        <div class="form-group">
          <label for="confirmPassword">Confirmă parola</label>
          <div class="input-wrapper">
            <i class="fas fa-lock"></i>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Reintrodu parola"
              autocomplete="new-password"
              required
            />
            <button type="button" class="password-toggle" id="confirmPasswordToggle" tabindex="-1" aria-label="Arată/ascunde parola">
              <i class="fas fa-eye"></i>
            </button>
          </div>
          <div class="form-error" id="confirmPasswordError">
            <i class="fas fa-exclamation-circle"></i>
            <span id="confirmPasswordErrorText"></span>
          </div>
        </div>

        <!-- Termeni și condiții -->
        <div class="form-options">
          <label class="terms-check" id="termsLabel">
            <input type="checkbox" name="terms" id="terms" <%= locals.terms ? 'checked' : '' %> />
            <span class="checkmark"><i class="fas fa-check"></i></span>
            Sunt de acord cu <a href="/terms" target="_blank">Termenii și condițiile</a> și <a href="/privacy" target="_blank">Politica de confidențialitate</a>.
          </label>
          <div class="terms-error" id="termsError">
            <i class="fas fa-exclamation-circle"></i>
            <span id="termsErrorText">Trebuie să accepți termenii și condițiile.</span>
          </div>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn-submit" id="submitBtn">
          <span class="spinner-btn"></span>
          <span class="btn-text"><i class="fas fa-user-plus"></i> Creează cont</span>
        </button>
      </form>

      <!-- Separator -->
      <div class="separator">
        <span>sau</span>
      </div>

      <!-- Login link -->
      <div class="login-link">
        Ai deja cont? <a href="/customer/login">Conectează-te aici</a>
      </div>
    </div>

    <!-- Footer -->
    <div class="register-footer">
      <span>&copy; <%= new Date().getFullYear() %> GastroHub. Toate drepturile rezervate.</span>
    </div>
  </div>

  <!-- ============================================================
       SCRIPTS
       ============================================================ -->
  <script>
    (function() {
      'use strict';

      // =================================================================
      // Background particles
      // =================================================================
      function createParticles() {
        var container = document.getElementById('bgParticles');
        if (!container) return;

        var count = window.innerWidth < 768 ? 8 : 16;
        var fragment = document.createDocumentFragment();

        for (var i = 0; i < count; i++) {
          var particle = document.createElement('div');
          particle.className = 'bg-particle';

          var size = Math.random() * 6 + 3;
          var left = Math.random() * 100;
          var delay = Math.random() * 14;
          var duration = Math.random() * 8 + 10;
          var opacity = Math.random() * 0.04 + 0.02;

          particle.style.cssText =
            'width:' + size + 'px;' +
            'height:' + size + 'px;' +
            'left:' + left + '%;' +
            'top:' + (Math.random() * 100) + '%;' +
            'animation-delay:' + delay + 's;' +
            'animation-duration:' + duration + 's;' +
            'opacity:' + opacity + ';';

          fragment.appendChild(particle);
        }

        container.appendChild(fragment);
      }

      // =================================================================
      // DOM references
      // =================================================================
      var form = document.getElementById('registerForm');
      var prenumeInput = document.getElementById('prenume');
      var numeInput = document.getElementById('nume');
      var emailInput = document.getElementById('email');
      var telefonInput = document.getElementById('telefon');
      var passwordInput = document.getElementById('password');
      var confirmPasswordInput = document.getElementById('confirmPassword');
      var termsCheckbox = document.getElementById('terms');
      var submitBtn = document.getElementById('submitBtn');

      var prenumeError = document.getElementById('prenumeError');
      var prenumeErrorText = document.getElementById('prenumeErrorText');
      var numeError = document.getElementById('numeError');
      var numeErrorText = document.getElementById('numeErrorText');
      var emailError = document.getElementById('emailError');
      var emailErrorText = document.getElementById('emailErrorText');
      var telefonError = document.getElementById('telefonError');
      var telefonErrorText = document.getElementById('telefonErrorText');
      var passwordError = document.getElementById('passwordError');
      var passwordErrorText = document.getElementById('passwordErrorText');
      var confirmPasswordError = document.getElementById('confirmPasswordError');
      var confirmPasswordErrorText = document.getElementById('confirmPasswordErrorText');
      var termsError = document.getElementById('termsError');
      var formAlert = document.getElementById('formAlert');
      var formAlertText = document.getElementById('formAlertText');

      var passwordToggle = document.getElementById('passwordToggle');
      var confirmPasswordToggle = document.getElementById('confirmPasswordToggle');

      var bar1 = document.getElementById('bar1');
      var bar2 = document.getElementById('bar2');
      var bar3 = document.getElementById('bar3');
      var bar4 = document.getElementById('bar4');
      var strengthText = document.getElementById('strengthText');

      var isSubmitting = false;

      // =================================================================
      // Password toggle visibility
      // =================================================================
      function setupPasswordToggle(toggleBtn, inputEl) {
        if (!toggleBtn || !inputEl) return;
        toggleBtn.addEventListener('click', function() {
          var isPassword = inputEl.type === 'password';
          inputEl.type = isPassword ? 'text' : 'password';
          toggleBtn.innerHTML = isPassword
            ? '<i class="fas fa-eye-slash"></i>'
            : '<i class="fas fa-eye"></i>';
        });
      }

      setupPasswordToggle(passwordToggle, passwordInput);
      setupPasswordToggle(confirmPasswordToggle, confirmPasswordInput);

      // =================================================================
      // Clear errors on input
      // =================================================================
      function hideError(errorEl) {
        if (errorEl) errorEl.classList.remove('show');
      }

      function hideFormAlert() {
        if (formAlert) formAlert.classList.remove('show');
      }

      if (prenumeInput) {
        prenumeInput.addEventListener('input', function() { hideError(prenumeError); hideFormAlert(); });
      }
      if (numeInput) {
        numeInput.addEventListener('input', function() { hideError(numeError); hideFormAlert(); });
      }
      if (emailInput) {
        emailInput.addEventListener('input', function() { hideError(emailError); hideFormAlert(); });
      }
      if (telefonInput) {
        telefonInput.addEventListener('input', function() { hideError(telefonError); hideFormAlert(); });
      }
      if (passwordInput) {
        passwordInput.addEventListener('input', function() {
          hideError(passwordError);
          hideFormAlert();
          updatePasswordStrength();
        });
      }
      if (confirmPasswordInput) {
        confirmPasswordInput.addEventListener('input', function() { hideError(confirmPasswordError); hideFormAlert(); });
      }
      if (termsCheckbox) {
        termsCheckbox.addEventListener('change', function() { hideError(termsError); hideFormAlert(); });
      }

      // =================================================================
      // Password strength meter
      // =================================================================
      function updatePasswordStrength() {
        var password = passwordInput ? passwordInput.value : '';
        var bars = [bar1, bar2, bar3, bar4];

        // Reset all bars
        bars.forEach(function(bar) {
          if (bar) {
            bar.className = 'strength-bar';
          }
        });
        if (strengthText) {
          strengthText.textContent = '';
          strengthText.className = 'strength-text';
        }

        if (!password) return;

        var score = 0;

        // Length checks
        if (password.length >= 6) score += 1;
        if (password.length >= 12) score += 1;

        // Complexity checks
        if (/[a-z]/.test(password)) score += 1;
        if (/[A-Z]/.test(password)) score += 1;
        if (/[0-9]/.test(password)) score += 1;
        if (/[^a-zA-Z0-9]/.test(password)) score += 1;

        // Determine level
        var level, label, cssClass;
        if (score <= 2) {
          level = 1;
          label = 'Slabă';
          cssClass = 'weak';
        } else if (score <= 4) {
          level = 2;
          label = 'Medie';
          cssClass = 'medium';
        } else {
          level = 4;
          label = 'Puternică';
          cssClass = 'strong';
        }

        // Color bars
        for (var i = 0; i < bars.length; i++) {
          if (bars[i] && i < level) {
            bars[i].classList.add(cssClass);
          }
        }

        if (strengthText) {
          strengthText.textContent = 'Putere parolă: ' + label;
          strengthText.classList.add(cssClass);
        }
      }

      // =================================================================
      // Client-side validation
      // =================================================================
      function validateForm() {
        var valid = true;

        // Prenume
        var prenume = prenumeInput ? prenumeInput.value.trim() : '';
        if (!prenume) {
          if (prenumeErrorText) prenumeErrorText.textContent = 'Prenumele este obligatoriu.';
          if (prenumeError) prenumeError.classList.add('show');
          valid = false;
        } else if (prenume.length < 2) {
          if (prenumeErrorText) prenumeErrorText.textContent = 'Prenumele trebuie să aibă cel puțin 2 caractere.';
          if (prenumeError) prenumeError.classList.add('show');
          valid = false;
        } else {
          hideError(prenumeError);
        }

        // Nume
        var nume = numeInput ? numeInput.value.trim() : '';
        if (!nume) {
          if (numeErrorText) numeErrorText.textContent = 'Numele este obligatoriu.';
          if (numeError) numeError.classList.add('show');
          valid = false;
        } else if (nume.length < 2) {
          if (numeErrorText) numeErrorText.textContent = 'Numele trebuie să aibă cel puțin 2 caractere.';
          if (numeError) numeError.classList.add('show');
          valid = false;
        } else {
          hideError(numeError);
        }

        // Email
        var email = emailInput ? emailInput.value.trim() : '';
        if (!email) {
          if (emailErrorText) emailErrorText.textContent = 'Adresa de email este obligatorie.';
          if (emailError) emailError.classList.add('show');
          valid = false;
        } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          if (emailErrorText) emailErrorText.textContent = 'Adresa de email nu este validă.';
          if (emailError) emailError.classList.add('show');
          valid = false;
        } else {
          hideError(emailError);
        }

        // Telefon (opțional, dar validat dacă este introdus)
        var telefon = telefonInput ? telefonInput.value.trim() : '';
        if (telefon && !/^(\+4|004)?0?7\d{8}$/.test(telefon.replace(/\s/g, ''))) {
          if (telefonErrorText) telefonErrorText.textContent = 'Numărul de telefon nu este valid (ex: 07xx xxx xxx).';
          if (telefonError) telefonError.classList.add('show');
          valid = false;
        } else {
          hideError(telefonError);
        }

        // Password
        var password = passwordInput ? passwordInput.value : '';
        if (!password) {
          if (passwordErrorText) passwordErrorText.textContent = 'Parola este obligatorie.';
          if (passwordError) passwordError.classList.add('show');
          valid = false;
        } else if (password.length < 6) {
          if (passwordErrorText) passwordErrorText.textContent = 'Parola trebuie să aibă cel puțin 8 caractere.';
          if (passwordError) passwordError.classList.add('show');
          valid = false;
        } else {
          hideError(passwordError);
        }

        // Confirm password
        var confirmPassword = confirmPasswordInput ? confirmPasswordInput.value : '';
        if (!confirmPassword) {
          if (confirmPasswordErrorText) confirmPasswordErrorText.textContent = 'Confirmarea parolei este obligatorie.';
          if (confirmPasswordError) confirmPasswordError.classList.add('show');
          valid = false;
        } else if (password && confirmPassword !== password) {
          if (confirmPasswordErrorText) confirmPasswordErrorText.textContent = 'Parolele nu coincid.';
          if (confirmPasswordError) confirmPasswordError.classList.add('show');
          valid = false;
        } else {
          hideError(confirmPasswordError);
        }

        // Terms
        if (termsCheckbox && !termsCheckbox.checked) {
          if (termsError) termsError.classList.add('show');
          valid = false;
        } else {
          hideError(termsError);
        }

        return valid;
      }

      // =================================================================
      // Set loading state
      // =================================================================
      function setLoading(loading) {
        if (submitBtn) {
          if (loading) {
            submitBtn.classList.add('loading');
            submitBtn.disabled = true;
          } else {
            submitBtn.classList.remove('loading');
            submitBtn.disabled = false;
          }
        }
      }

      // =================================================================
      // Submit handler — uses fetch to call API, then redirects on success
      // =================================================================
      if (form) {
        form.addEventListener('submit', function(e) {
          // Prevent default always — we handle submission via fetch
          e.preventDefault();

          // Client-side validation
          if (!validateForm()) {
            // Scroll to first error
            var firstError = form.querySelector('.form-error.show, .terms-error.show');
            if (firstError) {
              firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            return;
          }

          if (isSubmitting) {
            return;
          }

          isSubmitting = true;
          setLoading(true);
          hideFormAlert();

          // Build request body
          var body = {
            email: emailInput ? emailInput.value.trim() : '',
            password: passwordInput ? passwordInput.value : '',
            role: 'client'
          };

          // Optional fields
          var prenume = prenumeInput ? prenumeInput.value.trim() : '';
          var nume = numeInput ? numeInput.value.trim() : '';
          if (prenume || nume) {
            body.name = (prenume + ' ' + nume).trim();
          }

          var telefon = telefonInput ? telefonInput.value.trim() : '';
          if (telefon) {
            body.phone = telefon;
          }

          // Send register request to API
          fetch(form.action, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
            credentials: 'same-origin'  // Send cookies along
          })
            .then(function(response) {
              return response.json().then(function(data) {
                return { status: response.status, ok: response.ok, data: data };
              });
            })
            .then(function(result) {
              if (result.ok && result.data.success) {
                // Registration successful — redirect to dashboard
                window.location.href = '/customer/dashboard';
                return;
              }

              // Server returned an error
              var errorMsg = result.data.message || result.data.error || 'Eroare la înregistrare.';
              if (result.data.errors && Array.isArray(result.data.errors) && result.data.errors.length > 0) {
                errorMsg = result.data.errors.map(function(e) { return e.msg || e; }).join('; ');
              }

              // Check for duplicate email
              if (result.status === 409) {
                if (emailErrorText) emailErrorText.textContent = errorMsg;
                if (emailError) emailError.classList.add('show');
                emailInput.focus();
              } else {
                if (formAlert && formAlertText) {
                  formAlertText.textContent = errorMsg;
                  formAlert.classList.add('show');
                }
              }

              // Reset loading state
              setLoading(false);
              isSubmitting = false;
            })
            .catch(function(err) {
              // Network error or unexpected issue
              if (formAlert && formAlertText) {
                formAlertText.textContent = 'Eroare de rețea sau server indisponibil. Verifică conexiunea și încearcă din nou.';
                formAlert.classList.add('show');
              }
              setLoading(false);
              isSubmitting = false;
            });
        });
      }

      // =================================================================
      // If the page was rendered with an error (server-side),
      // reset the submit button state
      // =================================================================
      <% if (locals.error) { %>
        if (submitBtn) {
          submitBtn.classList.remove('loading');
          submitBtn.disabled = false;
          isSubmitting = false;
        }
      <% } %>

      // =================================================================
      // Init
      // =================================================================
      document.addEventListener('DOMContentLoaded', function() {
        createParticles();

        // Sync password strength on load if value pre-filled
        if (passwordInput && passwordInput.value) {
          updatePasswordStrength();
        }

        // Focus first empty field
        if (prenumeInput && !prenumeInput.value) {
          prenumeInput.focus();
        } else if (numeInput && !numeInput.value) {
          numeInput.focus();
        } else if (emailInput && !emailInput.value) {
          emailInput.focus();
        }
      });
    })();
  </script>
</body>
</html>