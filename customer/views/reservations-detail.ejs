<%
  // ============================================================
  // customer/views/reservations-detail.ejs
  // Detalii rezervare — afișare specifică rezervare
  // Folosește layout.ejs ca wrapper
  // ============================================================

  const user = locals.user || {};
  const customer = locals.customer || user || {};
  const reservationId = locals.reservationId || '';
%>

<style>
  /* ============================================================
     RESERVATION DETAIL STYLES
     ============================================================ */
  .reservation-detail-page .page-intro {
    margin-bottom: 24px;
  }

  .reservation-detail-page .page-intro h1 {
    font-size: 24px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .reservation-detail-page .page-intro h1 i {
    color: var(--color-primary);
  }

  .reservation-detail-page .page-intro .back-link {
    font-size: 14px;
    color: var(--color-text-muted);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    text-decoration: none;
  }

  .reservation-detail-page .page-intro .back-link:hover {
    color: var(--color-primary);
  }

  .detail-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  .detail-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 24px;
  }

  .detail-section h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border);
  }

  .detail-section h3 i {
    color: var(--color-primary);
  }

  .detail-field {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  .detail-field:last-child {
    border-bottom: none;
  }

  .detail-field .field-label {
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .detail-field .field-value {
    font-size: 14px;
    font-weight: 600;
    text-align: right;
    max-width: 60%;
  }

  .detail-actions-bar {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }

  .status-badge-large {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 16px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 20px;
  }

  .status-badge-large.confirmată,
  .status-badge-large.confirmed {
    background: #e6f4ea;
    color: #1e8e3e;
  }

  .status-badge-large.check-in,
  .status-badge-large.checked_in {
    background: #e3f2fd;
    color: #1565c0;
  }

  .status-badge-large.anulată,
  .status-badge-large.cancelled {
    background: #fce4ec;
    color: #c62828;
  }

  .status-badge-large.pending {
    background: #fff3e0;
    color: #e65100;
  }

  .status-badge-large.finalizată,
  .status-badge-large.completed {
    background: #f3e5f5;
    color: #6a1b9a;
  }

  .error-state {
    text-align: center;
    padding: 60px 20px;
  }

  .error-state i {
    font-size: 56px;
    opacity: 0.25;
    color: var(--color-danger);
    margin-bottom: 16px;
  }

  .error-state h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .error-state p {
    color: var(--color-text-muted);
    font-size: 14px;
    margin-bottom: 16px;
  }

  @media (max-width: 768px) {
    .detail-row {
      grid-template-columns: 1fr;
    }

    .reservation-detail-page .page-intro h1 {
      font-size: 20px;
    }
  }
</style>

<!-- ============================================================
     RESERVATION DETAIL PAGE
     ============================================================ -->
<div class="reservation-detail-page" data-page="reservation-detail" data-reservation-id="<%= reservationId %>" data-customer-id="<%= customer._id || '' %>" data-tenant-id="<%= customer.tenantId || '' %>">

  <!-- Page intro -->
  <div class="page-intro">
    <a href="/customer/reservations" class="back-link mb-1">
      <i class="fas fa-arrow-left"></i> Înapoi la rezervări
    </a>
    <h1>
      <i class="fas fa-calendar-check"></i>
      Detalii rezervare
    </h1>
    <p style="font-family:monospace;font-size:13px;color:var(--color-text-muted);">#<%= reservationId %></p>
  </div>

  <!-- Error state -->
  <div id="reservationError" class="error-state" style="display:none;">
    <i class="fas fa-exclamation-triangle"></i>
    <h3>Rezervarea nu a putut fi încărcată</h3>
    <p id="reservationErrorMsg">Detaliile nu sunt disponibile momentan.</p>
    <a href="/customer/reservations" class="btn btn-primary">
      <i class="fas fa-arrow-left"></i> Înapoi la rezervări
    </a>
  </div>

  <!-- Loading -->
  <div id="reservationLoading" class="spinner"></div>

  <!-- Detail content -->
  <div id="reservationContent" style="display:none;">
    <div class="detail-row">
      <!-- Info principale -->
      <div class="detail-section">
        <h3><i class="fas fa-info-circle"></i> Informații rezervare</h3>
        <div class="detail-field">
          <span class="field-label">Status</span>
          <span class="field-value" id="detailStatus"></span>
        </div>
        <div class="detail-field">
          <span class="field-label">Restaurant</span>
          <span class="field-value" id="detailRestaurant">—</span>
        </div>
        <div class="detail-field">
          <span class="field-label">Data și ora</span>
          <span class="field-value" id="detailDate">—</span>
        </div>
        <div class="detail-field">
          <span class="field-label">Număr persoane</span>
          <span class="field-value" id="detailGuests">—</span>
        </div>
        <div class="detail-field">
          <span class="field-label">Preferință masă</span>
          <span class="field-value" id="detailTablePref">—</span>
        </div>
        <div class="detail-field">
          <span class="field-label">Tip eveniment</span>
          <span class="field-value" id="detailEventType">—</span>
        </div>
      </div>

      <!-- Info secundare -->
      <div class="detail-section">
        <h3><i class="fas fa-sticky-note"></i> Detalii suplimentare</h3>
        <div class="detail-field">
          <span class="field-label">Creată la</span>
          <span class="field-value" id="detailCreatedAt">—</span>
        </div>
        <div class="detail-field">
          <span class="field-label">Actualizată la</span>
          <span class="field-value" id="detailUpdatedAt">—</span>
        </div>
        <div class="detail-field" style="flex-direction:column;align-items:flex-start;">
          <span class="field-label">Solicitări speciale</span>
          <span class="field-value" id="detailNotes" style="text-align:left;max-width:100%;margin-top:4px;">—</span>
        </div>
      </div>
    </div>

    <!-- Acțiuni -->
    <div class="detail-actions-bar" id="detailActions">
      <a href="/customer/reservations" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Înapoi
      </a>
      <button class="btn btn-danger btn-sm" id="cancelReservationBtn" onclick="cancelCurrentReservation()" style="display:none;">
        <i class="fas fa-ban"></i> Anulează rezervarea
      </button>
      <button class="btn btn-primary btn-sm" id="modifyReservationBtn" onclick="modifyReservation()" style="display:none;">
        <i class="fas fa-edit"></i> Modifică
      </button>
    </div>
  </div>
</div>

<!-- ============================================================
     SCRIPTS
     ============================================================ -->
<script>
  (function() {
    'use strict';

    var reservationId = '<%= reservationId %>';
    var tenantId = '<%= customer.tenantId || "" %>';
    var currentReservation = null;

    // ============================================================
    // Load reservation data
    // ============================================================
    async function loadReservation() {
      var loadingEl = document.getElementById('reservationLoading');
      var contentEl = document.getElementById('reservationContent');
      var errorEl = document.getElementById('reservationError');

      if (!reservationId) {
        showError('ID-ul rezervării lipsește.');
        return;
      }

      try {
        var data = await apiFetch('/api/reservations/' + reservationId + '?tenantId=' + tenantId);

        if (data && data.success && data.data) {
          var r = data.data.reservation || data.data;
          currentReservation = r;
          renderReservation(r);
          if (loadingEl) loadingEl.style.display = 'none';
          if (contentEl) contentEl.style.display = 'block';
          if (errorEl) errorEl.style.display = 'none';
        } else {
          showError('Rezervarea nu a fost găsită sau nu ai acces la ea.');
        }
      } catch (err) {
        showError('Eroare la încărcarea rezervării: ' + (err.message || 'Eroare necunoscută'));
      }
    }

    function showError(msg) {
      var loadingEl = document.getElementById('reservationLoading');
      var contentEl = document.getElementById('reservationContent');
      var errorEl = document.getElementById('reservationError');
      var errorMsg = document.getElementById('reservationErrorMsg');

      if (loadingEl) loadingEl.style.display = 'none';
      if (contentEl) contentEl.style.display = 'none';
      if (errorEl) errorEl.style.display = 'block';
      if (errorMsg) errorMsg.textContent = msg;
    }

    // ============================================================
    // Render reservation details
    // ============================================================
    function renderReservation(r) {
      if (!r) return;

      // Status
      var status = r.status || 'pending';
      var statusLabels = {
        'pending': 'În așteptare',
        'confirmată': 'Confirmată',
        'confirmed': 'Confirmată',
        'check-in': 'Check-in',
        'checked_in': 'Check-in',
        'anulată': 'Anulată',
        'cancelled': 'Anulată',
        'finalizată': 'Finalizată',
        'completed': 'Finalizată',
        'no-show': 'Neprezentare',
      };
      var statusLabel = statusLabels[status] || status;
      var statusBadgeClass = status.replace(/\s+/g, '-').replace(/ă/g, 'a').toLowerCase();
      document.getElementById('detailStatus').innerHTML = '<span class="status-badge-large ' + statusBadgeClass + '">' + escapeHtml(statusLabel) + '</span>';

      // Restaurant
      var restaurantName = (r.restaurantId && r.restaurantId.name) ? r.restaurantId.name : (r.restaurantName || '—');
      document.getElementById('detailRestaurant').textContent = restaurantName;

      // Date
      var dateStr = r.date || r.reservationDate || r.createdAt;
      document.getElementById('detailDate').textContent = dateStr ? formatDate(dateStr) : '—';

      // Guests
      document.getElementById('detailGuests').textContent = (r.guests || r.numberOfGuests || '—');

      // Table preference
      var tablePrefMap = {
        'interior': 'Interior', 'terasa': 'Terasă', 'fumatori': 'Fumători',
        'nefumatori': 'Nefumători', 'fereastra': 'Lângă fereastră', 'vip': 'VIP',
      };
      document.getElementById('detailTablePref').textContent = tablePrefMap[r.tablePreference] || r.tablePreference || '—';

      // Event type
      var eventMap = {
        'aniversare': '🎂 Aniversare', 'ziua-nasterii': '🎉 Zi de naștere',
        'cina-romantica': '💕 Cină romantică', 'business': '💼 Business',
        'familie': '👨‍👩‍👧‍👦 Familie', 'grup': '👥 Grup', 'altele': 'Altele',
      };
      document.getElementById('detailEventType').textContent = eventMap[r.eventType] || r.eventType || '—';

      // Dates
      document.getElementById('detailCreatedAt').textContent = r.createdAt ? formatDate(r.createdAt) : '—';
      document.getElementById('detailUpdatedAt').textContent = r.updatedAt ? formatDate(r.updatedAt) : '—';

      // Notes
      document.getElementById('detailNotes').textContent = r.notes || r.solicitariSpeciale || '—';

      // Actions based on status
      var canCancel = (status === 'pending' || status === 'confirmată' || status === 'confirmed');
      var canModify = (status === 'pending' || status === 'confirmată' || status === 'confirmed');

      var cancelBtn = document.getElementById('cancelReservationBtn');
      var modifyBtn = document.getElementById('modifyReservationBtn');

      if (cancelBtn) cancelBtn.style.display = canCancel ? 'inline-flex' : 'none';
      if (modifyBtn) modifyBtn.style.display = canModify ? 'inline-flex' : 'none';
    }

    // ============================================================
    // Cancel reservation
    // ============================================================
    window.cancelCurrentReservation = async function() {
      if (!reservationId) return;
      if (!confirm('Ești sigur că vrei să anulezi această rezervare?')) return;

      try {
        var data = await apiFetch('/api/reservations/' + reservationId + '/cancel', {
          method: 'PUT',
          body: JSON.stringify({ tenantId: tenantId })
        });

        if (data && data.success) {
          showToast('Rezervarea a fost anulată cu succes.', 'success');
          setTimeout(function() { window.location.reload(); }, 1200);
        }
      } catch (err) {
        showToast('Eroare la anularea rezervării.', 'error');
      }
    };

    // ============================================================
    // Modify reservation (redirect to edit page)
    // ============================================================
    window.modifyReservation = function() {
      window.location.href = '/customer/reservations/new?edit=' + reservationId;
    };

    // ============================================================
    // Helper: escape HTML
    // ============================================================
    function escapeHtml(text) {
      if (!text) return '—';
      var div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // ============================================================
    // Init
    // ============================================================
    document.addEventListener('DOMContentLoaded', function() {
      loadReservation();
    });

  })();
</script>
