<%
  // ============================================================
  // customer/views/orders-detail.ejs
  // Detalii comandă specifică
  // Folosește layout.ejs ca wrapper
  // ============================================================

  const user = locals.user || {};
  const customer = locals.customer || user || {};
  const orderId = locals.orderId || '';
%>

<style>
  /* ============================================================
     ORDER DETAIL STYLES
     ============================================================ */
  .order-detail-page .page-intro {
    margin-bottom: 24px;
  }

  .order-detail-page .page-intro h1 {
    font-size: 24px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .order-detail-page .page-intro h1 i {
    color: var(--color-primary);
  }

  .order-detail-page .page-intro .back-link {
    font-size: 14px;
    color: var(--color-text-muted);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    text-decoration: none;
  }

  .order-detail-page .page-intro .back-link:hover {
    color: var(--color-primary);
  }

  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  .detail-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 24px;
  }

  .detail-card.full-width {
    grid-column: 1 / -1;
  }

  .detail-card h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border);
  }

  .detail-card h3 i {
    color: var(--color-primary);
  }

  .detail-field {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  .detail-field:last-child {
    border-bottom: none;
  }

  .detail-field .field-label {
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .detail-field .field-value {
    font-size: 14px;
    font-weight: 600;
    text-align: right;
    max-width: 60%;
  }

  .status-badge-large {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 16px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 20px;
  }

  .status-badge-large.deschisă,
  .status-badge-large.processing {
    background: #fff3e0;
    color: #e65100;
  }

  .status-badge-large.în-preparare,
  .status-badge-large.preparing {
    background: #e3f2fd;
    color: #1565c0;
  }

  .status-badge-large.finalizată,
  .status-badge-large.completed {
    background: #f3e5f5;
    color: #6a1b9a;
  }

  .status-badge-large.livrată,
  .status-badge-large.delivered {
    background: #e8f5e9;
    color: #2e7d32;
  }

  .status-badge-large.achitată {
    background: #e8f5e9;
    color: #1b5e20;
  }

  .status-badge-large.anulată,
  .status-badge-large.cancelled {
    background: #fce4ec;
    color: #b71c1c;
  }

  .status-badge-large.pending {
    background: #fff8e1;
    color: #f57f17;
  }

  /* Timeline */
  .order-timeline {
    margin-top: 10px;
  }

  /* Items table */
  .items-table-detail {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .items-table-detail th {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 10px 12px;
    text-align: left;
    background: var(--color-bg);
    border-bottom: 2px solid var(--color-border);
  }

  .items-table-detail td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--color-border);
  }

  .items-table-detail tr:last-child td {
    border-bottom: none;
  }

  .items-table-detail .total-row td {
    font-weight: 700;
    font-size: 14px;
    border-top: 2px solid var(--color-border);
    background: rgba(13, 110, 253, 0.02);
  }

  .detail-actions-bar {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }

  .error-state {
    text-align: center;
    padding: 60px 20px;
  }

  .error-state i {
    font-size: 56px;
    opacity: 0.25;
    color: var(--color-danger);
    margin-bottom: 16px;
  }

  .error-state h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .error-state p {
    color: var(--color-text-muted);
    font-size: 14px;
    margin-bottom: 16px;
  }

  @media (max-width: 768px) {
    .detail-layout {
      grid-template-columns: 1fr;
    }

    .order-detail-page .page-intro h1 {
      font-size: 20px;
    }
  }
</style>

<!-- ============================================================
     ORDER DETAIL PAGE
     ============================================================ -->
<div class="order-detail-page" data-page="order-detail" data-order-id="<%= orderId %>" data-customer-id="<%= customer._id || '' %>" data-tenant-id="<%= customer.tenantId || '' %>">

  <!-- Page intro -->
  <div class="page-intro">
    <a href="/customer/orders" class="back-link mb-1">
      <i class="fas fa-arrow-left"></i> Înapoi la comenzi
    </a>
    <h1>
      <i class="fas fa-receipt"></i>
      Detalii comandă
    </h1>
    <p style="font-family:monospace;font-size:13px;color:var(--color-text-muted);">#<%= orderId %></p>
  </div>

  <!-- Error state -->
  <div id="orderError" class="error-state" style="display:none;">
    <i class="fas fa-exclamation-triangle"></i>
    <h3>Comanda nu a putut fi încărcată</h3>
    <p id="orderErrorMsg">Detaliile nu sunt disponibile momentan.</p>
    <a href="/customer/orders" class="btn btn-primary">
      <i class="fas fa-arrow-left"></i> Înapoi la comenzi
    </a>
  </div>

  <!-- Loading -->
  <div id="orderLoading" class="spinner"></div>

  <!-- Detail content -->
  <div id="orderContent" style="display:none;">
    <div class="detail-layout">
      <!-- Info principale -->
      <div class="detail-card">
        <h3><i class="fas fa-info-circle"></i> Informații comandă</h3>
        <div class="detail-field">
          <span class="field-label">Status</span>
          <span class="field-value" id="detailStatus"></span>
        </div>
        <div class="detail-field">
          <span class="field-label">Restaurant</span>
          <span class="field-value" id="detailRestaurant">—</span>
        </div>
        <div class="detail-field">
          <span class="field-label">Data plasării</span>
          <span class="field-value" id="detailDate">—</span>
        </div>
        <div class="detail-field">
          <span class="field-label">Tip livrare</span>
          <span class="field-value" id="detailDeliveryType">—</span>
        </div>
        <div class="detail-field">
          <span class="field-label">Adresă / Masă</span>
          <span class="field-value" id="detailDeliveryInfo">—</span>
        </div>
        <div class="detail-field">
          <span class="field-label">Notițe</span>
          <span class="field-value" id="detailNotes" style="text-align:left;max-width:100%;">—</span>
        </div>
      </div>

      <!-- Timeline -->
      <div class="detail-card">
        <h3><i class="fas fa-history"></i> Status comandă</h3>
        <div class="order-timeline" id="orderTimeline">
          <!-- Populated dynamically -->
        </div>
      </div>

      <!-- Articole -->
      <div class="detail-card full-width">
        <h3><i class="fas fa-utensils"></i> Articole comandate</h3>
        <div class="table-wrapper">
          <table class="items-table-detail" id="itemsTable">
            <thead>
              <tr>
                <th>Articol</th>
                <th>Cant.</th>
                <th>Preț unitar</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody id="itemsTableBody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Acțiuni -->
    <div class="detail-actions-bar" id="detailActions">
      <a href="/customer/orders" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Înapoi
      </a>
      <button class="btn btn-primary btn-sm" id="repeatOrderBtn" onclick="repeatCurrentOrder()">
        <i class="fas fa-redo"></i> Comandă din nou
      </button>
      <button class="btn btn-danger btn-sm" id="cancelOrderBtn" onclick="cancelCurrentOrder()" style="display:none;">
        <i class="fas fa-ban"></i> Anulează comanda
      </button>
      <button class="btn btn-sm btn-secondary no-print" onclick="window.print()">
        <i class="fas fa-print"></i> Printează
      </button>
    </div>
  </div>
</div>

<!-- ============================================================
     SCRIPTS
     ============================================================ -->
<script>
  (function() {
    'use strict';

    var orderId = '<%= orderId %>';
    var tenantId = '<%= customer.tenantId || "" %>';
    var currentOrder = null;

    // ============================================================
    // Load order
    // ============================================================
    async function loadOrder() {
      var loadingEl = document.getElementById('orderLoading');
      var contentEl = document.getElementById('orderContent');
      var errorEl = document.getElementById('orderError');

      if (!orderId) {
        showError('ID-ul comenzii lipsește.');
        return;
      }

      try {
        var data = await apiFetch('/api/orders/' + orderId + '?tenantId=' + tenantId);

        if (data && data.success && data.data) {
          var order = data.data.order || data.data;
          currentOrder = order;
          renderOrder(order);
          if (loadingEl) loadingEl.style.display = 'none';
          if (contentEl) contentEl.style.display = 'block';
          if (errorEl) errorEl.style.display = 'none';
        } else {
          showError('Comanda nu a fost găsită sau nu ai acces la ea.');
        }
      } catch (err) {
        showError('Eroare la încărcarea comenzii: ' + (err.message || 'Eroare necunoscută'));
      }
    }

    function showError(msg) {
      var loadingEl = document.getElementById('orderLoading');
      var contentEl = document.getElementById('orderContent');
      var errorEl = document.getElementById('orderError');
      var errorMsg = document.getElementById('orderErrorMsg');

      if (loadingEl) loadingEl.style.display = 'none';
      if (contentEl) contentEl.style.display = 'none';
      if (errorEl) errorEl.style.display = 'block';
      if (errorMsg) errorMsg.textContent = msg;
    }

    // ============================================================
    // Render order
    // ============================================================
    function renderOrder(order) {
      if (!order) return;

      // Status
      var status = order.status || 'pending';
      var statusLabels = {
        'pending': 'În așteptare', 'deschisă': 'Deschisă', 'în preparare': 'În preparare',
        'preparing': 'În preparare', 'finalizată': 'Finalizată', 'livrată': 'Livrată',
        'achitată': 'Achitată', 'anulată': 'Anulată', 'processing': 'În procesare',
        'confirmed': 'Confirmată', 'completed': 'Finalizată', 'delivered': 'Livrată',
        'cancelled': 'Anulată', 'refunded': 'Rambursată',
      };
      var statusLabel = statusLabels[status] || status;
      var statusClass = status.replace(/\s+/g, '-').replace(/ă/g, 'a').toLowerCase();
      document.getElementById('detailStatus').innerHTML = '<span class="status-badge-large ' + statusClass + '">' + escapeHtml(statusLabel) + '</span>';

      // Restaurant
      var restaurantName = (order.restaurantId && order.restaurantId.name) ? order.restaurantId.name : (order.restaurantName || '—');
      document.getElementById('detailRestaurant').textContent = restaurantName;

      // Date
      var dateStr = order.createdAt || order.date || '';
      document.getElementById('detailDate').textContent = dateStr ? formatDate(dateStr) : '—';

      // Delivery type
      var deliveryLabels = { 'ridicare': 'Ridicare din restaurant', 'curier': 'Livrare la domiciliu', 'la-masa': 'Servire la masă' };
      var deliveryType = order.deliveryType || order.tipLivrare || 'ridicare';
      document.getElementById('detailDeliveryType').textContent = deliveryLabels[deliveryType] || deliveryType;

      // Delivery info
      var deliveryInfo = '—';
      if (deliveryType === 'curier') {
        deliveryInfo = order.deliveryAddress || order.adresaLivrare || '—';
      } else if (deliveryType === 'la-masa') {
        deliveryInfo = 'Masa ' + (order.tableNumber || order.masa || '—');
      }
      document.getElementById('detailDeliveryInfo').textContent = deliveryInfo;

      // Notes
      document.getElementById('detailNotes').textContent = order.notes || order.notite || '—';

      // Timeline
      renderTimeline(status);

      // Items table
      renderItems(order.articole || order.items || []);

      // Action buttons
      var canCancel = (status === 'pending' || status === 'deschisă' || status === 'confirmată' || status === 'confirmed' || status === 'processing' || status === 'în preparare' || status === 'preparing');
      document.getElementById('cancelOrderBtn').style.display = canCancel ? 'inline-flex' : 'none';
    }

    function renderTimeline(status) {
      var timeline = document.getElementById('orderTimeline');
      if (!timeline) return;

      var steps = [
        { key: 'pending', label: 'Comandă plasată', icon: 'fa-check-circle' },
        { key: 'confirmed', label: 'Confirmată de restaurant', icon: 'fa-clipboard-check' },
        { key: 'preparing', label: 'În preparare', icon: 'fa-fire' },
        { key: 'completed', label: 'Finalizată', icon: 'fa-check-double' },
        { key: 'delivered', label: 'Livrată', icon: 'fa-truck' },
        { key: 'achitată', label: 'Achitată', icon: 'fa-credit-card' },
      ];

      var statusOrder = ['pending', 'confirmed', 'preparing', 'în preparare', 'completed', 'finalizată', 'delivered', 'livrată', 'achitată'];
      var currentIdx = statusOrder.indexOf(status);
      if (currentIdx === -1) currentIdx = 0;

      // Normalize status to step key
      var normalizedStatus = status;
      if (status === 'deschisă') normalizedStatus = 'pending';
      if (status === 'în preparare') normalizedStatus = 'preparing';
      if (status === 'finalizată') normalizedStatus = 'completed';
      if (status === 'livrată') normalizedStatus = 'delivered';

      if (status === 'anulată' || status === 'cancelled') {
        timeline.innerHTML = '<div class="timeline-item active"><div class="timeline-title"><i class="fas fa-ban" style="color:var(--color-danger);"></i> Comandă anulată</div></div>';
        return;
      }

      var html = '';
      steps.forEach(function(step, idx) {
        var isCompleted = statusOrder.indexOf(normalizedStatus) >= statusOrder.indexOf(step.key);
        var isActive = step.key === normalizedStatus;

        var cls = 'timeline-item';
        if (isCompleted && !isActive) cls += ' completed';
        if (isActive) cls += ' active';

        html += '<div class="' + cls + '">' +
          '<div class="timeline-title"><i class="fas ' + step.icon + '"></i> ' + step.label + '</div>' +
        '</div>';
      });

      timeline.innerHTML = html;
    }

    function renderItems(articole) {
      var tbody = document.getElementById('itemsTableBody');
      if (!tbody) return;

      if (!articole || articole.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--color-text-muted);padding:20px;">Niciun articol</td></tr>';
        return;
      }

      var total = 0;
      tbody.innerHTML = '';

      articole.forEach(function(item) {
        var nume = item.nume || item.name || 'Articol';
        var cantitate = item.cantitate || item.quantity || 1;
        var pret = item.pret || item.price || 0;
        var subtotal = pret * cantitate;
        total += subtotal;

        var tr = document.createElement('tr');
        tr.innerHTML =
          '<td>' + escapeHtml(nume) + '</td>' +
          '<td>' + cantitate + '</td>' +
          '<td>' + formatCurrency(pret) + '</td>' +
          '<td style="font-weight:600;">' + formatCurrency(subtotal) + '</td>';
        tbody.appendChild(tr);
      });

      // Total row
      var trTotal = document.createElement('tr');
      trTotal.className = 'total-row';
      trTotal.innerHTML =
        '<td colspan="3" style="text-align:right;">Total</td>' +
        '<td>' + formatCurrency(total) + '</td>';
      tbody.appendChild(trTotal);
    }

    // ============================================================
    // Actions
    // ============================================================
    window.repeatCurrentOrder = function() {
      if (!currentOrder) return;
      window.location.href = '/customer/orders/new';
    };

    window.cancelCurrentOrder = async function() {
      if (!orderId) return;
      if (!confirm('Ești sigur că vrei să anulezi această comandă?')) return;

      try {
        var data = await apiFetch('/api/orders/' + orderId + '/cancel', {
          method: 'PUT',
          body: JSON.stringify({ tenantId: tenantId })
        });

        if (data && data.success) {
          showToast('Comanda a fost anulată cu succes.', 'success');
          setTimeout(function() { window.location.reload(); }, 1200);
        }
      } catch (err) {
        showToast('Eroare la anularea comenzii.', 'error');
      }
    };

    // ============================================================
    // Helpers
    // ============================================================
    function escapeHtml(text) {
      if (!text) return '—';
      var div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // ============================================================
    // Init
    // ============================================================
    document.addEventListener('DOMContentLoaded', function() {
      loadOrder();
    });

  })();
</script>
