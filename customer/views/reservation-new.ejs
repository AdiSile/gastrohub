<%
  // ============================================================
  // customer/views/reservation-new.ejs
  // Formular creare rezervare nouă
  // Folosește layout.ejs ca wrapper
  // ============================================================

  const user = locals.user || {};
  const customer = locals.customer || user || {};
%>

<style>
  /* ============================================================
     RESERVATION NEW — Formular stilizat
     ============================================================ */
  .reservation-new-page .page-intro {
    margin-bottom: 24px;
  }

  .reservation-new-page .page-intro h1 {
    font-size: 24px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .reservation-new-page .page-intro h1 i {
    color: var(--color-primary);
  }

  .reservation-new-page .page-intro p {
    color: var(--color-text-muted);
    margin-top: 4px;
    font-size: 14px;
  }

  .reservation-form-card {
    max-width: 700px;
    margin: 0 auto;
  }

  .reservation-form-card .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .reservation-form-card .card-header {
    background: rgba(13, 110, 253, 0.04);
    border-bottom: 1px solid var(--color-border);
    padding: 20px 24px;
    font-weight: 600;
    font-size: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    margin: 0;
  }

  .reservation-form-card .card-header i {
    color: var(--color-primary);
    font-size: 18px;
  }

  .reservation-form-card .card-body {
    padding: 28px 24px;
  }

  .form-row-duo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }

  .reservation-summary-preview {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 16px;
    margin-top: 20px;
    display: none;
  }

  .reservation-summary-preview.visible {
    display: block;
  }

  .reservation-summary-preview h4 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--color-text);
  }

  .reservation-summary-preview h4 i {
    color: var(--color-primary);
  }

  .reservation-summary-preview .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    padding: 6px 0;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  .reservation-summary-preview .summary-row:last-child {
    border-bottom: none;
  }

  .reservation-summary-preview .summary-row .label {
    color: var(--color-text-muted);
  }

  .reservation-summary-preview .summary-row .value {
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .form-row-duo {
      grid-template-columns: 1fr;
    }

    .reservation-form-card .card-body {
      padding: 20px 16px;
    }

    .form-actions {
      flex-direction: column;
    }

    .form-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .reservation-new-page .page-intro h1 {
      font-size: 20px;
    }
  }
</style>

<!-- ============================================================
     RESERVATION NEW PAGE
     ============================================================ -->
<div class="reservation-new-page" data-page="reservation-new" data-customer-id="<%= customer._id || '' %>" data-tenant-id="<%= customer.tenantId || '' %>">

  <!-- Page intro -->
  <div class="page-intro">
    <h1>
      <i class="fas fa-calendar-plus"></i>
      Rezervare nouă
    </h1>
    <p>Completează datele de mai jos pentru a crea o rezervare la restaurantul preferat.</p>
  </div>

  <!-- Flash messages -->
  <% if (locals.flash && flash.message) { %>
    <div class="alert" style="margin-bottom:20px;padding:12px 16px;border-radius:8px;background:<%= flash.type === 'success' ? '#e8f5e9' : flash.type === 'error' ? '#fce4ec' : '#e3f2fd' %>;color:<%= flash.type === 'success' ? '#2e7d32' : flash.type === 'error' ? '#c62828' : '#1565c0' %>;">
      <i class="fas fa-<%= flash.type === 'success' ? 'check-circle' : flash.type === 'error' ? 'exclamation-circle' : 'info-circle' %>"></i>
      <%= flash.message %>
    </div>
  <% } %>

  <!-- Form card -->
  <div class="reservation-form-card">
    <div class="card">
      <div class="card-header">
        <i class="fas fa-calendar-plus"></i>
        Detalii rezervare
      </div>
      <div class="card-body">
        <form id="reservationNewForm" novalidate>
          <!-- Restaurant & Data -->
          <div class="form-row-duo">
            <div class="form-group">
              <label for="restaurantId">Restaurant <span style="color:var(--color-danger);">*</span></label>
              <select id="restaurantId" name="restaurantId" required>
                <option value="">— Selectează restaurantul —</option>
              </select>
              <div class="form-error" id="restaurantIdError"></div>
            </div>

            <div class="form-group">
              <label for="reservationDate">Data și ora <span style="color:var(--color-danger);">*</span></label>
              <input type="datetime-local" id="reservationDate" name="reservationDate" required />
              <div class="form-hint">Selectează o dată și oră în viitor</div>
              <div class="form-error" id="reservationDateError"></div>
            </div>
          </div>

          <!-- Persoane & Preferință masă -->
          <div class="form-row-duo">
            <div class="form-group">
              <label for="guests">Număr persoane <span style="color:var(--color-danger);">*</span></label>
              <input type="number" id="guests" name="guests" min="1" max="50" value="2" required />
              <div class="form-hint">Între 1 și 50 de persoane</div>
              <div class="form-error" id="guestsError"></div>
            </div>

            <div class="form-group">
              <label for="tablePreference">Preferință masă</label>
              <select id="tablePreference" name="tablePreference">
                <option value="">— Indiferent —</option>
                <option value="interior">Interior</option>
                <option value="terasa">Terasă</option>
                <option value="fumatori">Fumători</option>
                <option value="nefumatori">Nefumători</option>
                <option value="fereastra">Lângă fereastră</option>
                <option value="vip">VIP</option>
              </select>
            </div>
          </div>

          <!-- Eveniment special -->
          <div class="form-group">
            <label for="eventType">Tip eveniment <span style="font-weight:400;color:var(--color-text-muted);">(opțional)</span></label>
            <select id="eventType" name="eventType">
              <option value="">— Ocazie obișnuită —</option>
              <option value="aniversare">🎂 Aniversare</option>
              <option value="ziua-nasterii">🎉 Zi de naștere</option>
              <option value="cina-romantica">💕 Cină romantică</option>
              <option value="business">💼 Business</option>
              <option value="familie">👨‍👩‍👧‍👦 Familie</option>
              <option value="grup">👥 Grup</option>
              <option value="altele">Altele</option>
            </select>
          </div>

          <!-- Solicitări speciale -->
          <div class="form-group">
            <label for="notes">Solicitări speciale</label>
            <textarea id="notes" name="notes" rows="3" placeholder="Ex: aniversare, alergie la gluten, scaun copil, tort surpriză…" maxlength="500"></textarea>
            <div class="form-hint"><span id="notesCount">0</span> / 500 caractere</div>
          </div>

          <!-- Sumar preview -->
          <div class="reservation-summary-preview" id="summaryPreview">
            <h4><i class="fas fa-clipboard-check"></i> Sumar rezervare</h4>
            <div class="summary-row">
              <span class="label">Restaurant</span>
              <span class="value" id="summaryRestaurant">—</span>
            </div>
            <div class="summary-row">
              <span class="label">Data și ora</span>
              <span class="value" id="summaryDate">—</span>
            </div>
            <div class="summary-row">
              <span class="label">Număr persoane</span>
              <span class="value" id="summaryGuests">—</span>
            </div>
            <div class="summary-row">
              <span class="label">Preferință masă</span>
              <span class="value" id="summaryTablePref">—</span>
            </div>
          </div>

          <!-- Acțiuni -->
          <div class="form-actions">
            <button type="button" class="btn btn-secondary" onclick="resetReservationForm()">
              <i class="fas fa-undo"></i> Resetează
            </button>
            <button type="submit" class="btn btn-primary" id="submitReservationBtn">
              <i class="fas fa-check"></i> <span>Confirmă rezervarea</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- ============================================================
     SCRIPTS
     ============================================================ -->
<script>
  (function() {
    'use strict';

    // ============================================================
    // State
    // ============================================================
    var customerId = '<%= customer._id || "" %>';
    var tenantId = '<%= customer.tenantId || "" %>';
    var isSubmitting = false;
    var restaurants = [];

    // ============================================================
    // DOM references
    // ============================================================
    var form = document.getElementById('reservationNewForm');
    var restaurantSelect = document.getElementById('restaurantId');
    var dateInput = document.getElementById('reservationDate');
    var guestsInput = document.getElementById('guests');
    var tablePrefSelect = document.getElementById('tablePreference');
    var eventTypeSelect = document.getElementById('eventType');
    var notesTextarea = document.getElementById('notes');
    var notesCountEl = document.getElementById('notesCount');
    var submitBtn = document.getElementById('submitReservationBtn');
    var summaryPreview = document.getElementById('summaryPreview');

    var restaurantError = document.getElementById('restaurantIdError');
    var dateError = document.getElementById('reservationDateError');
    var guestsError = document.getElementById('guestsError');

    // ============================================================
    // Init
    // ============================================================
    document.addEventListener('DOMContentLoaded', function() {
      setMinDate();
      loadRestaurants();

      // Caracter count
      if (notesTextarea && notesCountEl) {
        notesTextarea.addEventListener('input', function() {
          notesCountEl.textContent = this.value.length;
          updateSummary();
        });
      }

      // Live summary updates
      if (restaurantSelect) {
        restaurantSelect.addEventListener('change', updateSummary);
      }
      if (dateInput) {
        dateInput.addEventListener('change', updateSummary);
      }
      if (guestsInput) {
        guestsInput.addEventListener('input', updateSummary);
      }
      if (tablePrefSelect) {
        tablePrefSelect.addEventListener('change', updateSummary);
      }

      // Clear errors on input
      if (restaurantSelect) restaurantSelect.addEventListener('change', function() { clearError(restaurantError); });
      if (dateInput) dateInput.addEventListener('change', function() { clearError(dateError); });
      if (guestsInput) guestsInput.addEventListener('input', function() { clearError(guestsError); });

      // Submit
      if (form) {
        form.addEventListener('submit', handleSubmit);
      }
    });

    // ============================================================
    // Setează data minimă
    // ============================================================
    function setMinDate() {
      if (!dateInput) return;
      var now = new Date();
      var year = now.getFullYear();
      var month = String(now.getMonth() + 1).padStart(2, '0');
      var day = String(now.getDate()).padStart(2, '0');
      var hours = String(now.getHours()).padStart(2, '0');
      var minutes = String(now.getMinutes()).padStart(2, '0');
      dateInput.setAttribute('min', year + '-' + month + '-' + day + 'T' + hours + ':' + minutes);
    }

    // ============================================================
    // Încărcare restaurante
    // ============================================================
    async function loadRestaurants() {
      try {
        var data = await apiFetch('/api/restaurants?tenantId=' + tenantId + '&limit=100');
        if (data && data.success && data.data && data.data.restaurants) {
          restaurants = data.data.restaurants;
          if (restaurantSelect) {
            restaurantSelect.innerHTML = '<option value="">— Selectează restaurantul —</option>';
            restaurants.forEach(function(r) {
              var opt = document.createElement('option');
              opt.value = r._id;
              opt.textContent = r.name || r.nume || 'Restaurant';
              restaurantSelect.appendChild(opt);
            });
          }
        }
      } catch (err) {
        console.error('Eroare la încărcarea restaurantelor:', err);
      }
    }

    // ============================================================
    // Actualizare sumar preview
    // ============================================================
    function updateSummary() {
      if (!summaryPreview) return;

      var restaurantName = '—';
      if (restaurantSelect && restaurantSelect.selectedIndex > 0) {
        restaurantName = restaurantSelect.options[restaurantSelect.selectedIndex].textContent;
      }

      var dateVal = dateInput ? dateInput.value : '';
      var formattedDate = dateVal ? new Date(dateVal).toLocaleString('ro-RO', {
        day: '2-digit', month: '2-digit', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
      }) : '—';

      var guests = guestsInput ? guestsInput.value : '—';
      var tablePref = tablePrefSelect && tablePrefSelect.value ? tablePrefSelect.options[tablePrefSelect.selectedIndex].textContent : '—';

      document.getElementById('summaryRestaurant').textContent = restaurantName;
      document.getElementById('summaryDate').textContent = formattedDate;
      document.getElementById('summaryGuests').textContent = guests;
      document.getElementById('summaryTablePref').textContent = tablePref;

      var hasData = restaurantSelect && restaurantSelect.value && dateInput && dateInput.value;
      summaryPreview.classList.toggle('visible', !!hasData);
    }

    // ============================================================
    // Clear error
    // ============================================================
    function clearError(el) {
      if (el) el.textContent = '';
    }

    // ============================================================
    // Validare
    // ============================================================
    function validateForm() {
      var errors = [];

      if (!restaurantSelect || !restaurantSelect.value) {
        errors.push('Selectează un restaurant.');
        if (restaurantError) restaurantError.textContent = 'Câmp obligatoriu';
      } else {
        clearError(restaurantError);
      }

      if (!dateInput || !dateInput.value) {
        errors.push('Selectează data și ora.');
        if (dateError) dateError.textContent = 'Câmp obligatoriu';
      } else {
        var selected = new Date(dateInput.value);
        if (selected <= new Date()) {
          errors.push('Data trebuie să fie în viitor.');
          if (dateError) dateError.textContent = 'Data trebuie să fie în viitor';
        } else {
          clearError(dateError);
        }
      }

      var guests = guestsInput ? parseInt(guestsInput.value, 10) : 0;
      if (!guests || guests < 1) {
        errors.push('Numărul de persoane trebuie să fie minim 1.');
        if (guestsError) guestsError.textContent = 'Minimum 1 persoană';
      } else if (guests > 50) {
        errors.push('Maximum 50 de persoane.');
        if (guestsError) guestsError.textContent = 'Maximum 50 persoane';
      } else {
        clearError(guestsError);
      }

      return errors;
    }

    // ============================================================
    // Submit handler
    // ============================================================
    async function handleSubmit(e) {
      e.preventDefault();
      if (isSubmitting) return;

      var errors = validateForm();
      if (errors.length > 0) {
        errors.forEach(function(err) { showToast(err, 'error'); });
        return;
      }

      isSubmitting = true;
      submitBtn.disabled = true;
      submitBtn.querySelector('span').textContent = 'Se trimite…';

      var payload = {
        tenantId: tenantId,
        customerId: customerId,
        restaurantId: restaurantSelect.value,
        date: dateInput.value,
        guests: parseInt(guestsInput.value, 10),
        tablePreference: tablePrefSelect.value || undefined,
        eventType: eventTypeSelect ? eventTypeSelect.value || undefined : undefined,
        notes: notesTextarea ? notesTextarea.value || undefined : undefined,
      };

      try {
        var data = await apiFetch('/api/reservations', {
          method: 'POST',
          body: JSON.stringify(payload)
        });

        if (data && data.success) {
          showToast('Rezervarea a fost creată cu succes!', 'success');
          setTimeout(function() {
            window.location.href = '/customer/reservations';
          }, 1500);
        }
      } catch (err) {
        showToast('Eroare la crearea rezervării.', 'error');
      } finally {
        isSubmitting = false;
        submitBtn.disabled = false;
        submitBtn.querySelector('span').textContent = 'Confirmă rezervarea';
      }
    }

    // ============================================================
    // Reset form
    // ============================================================
    window.resetReservationForm = function() {
      if (form) form.reset();
      guestsInput.value = 2;
      if (notesCountEl) notesCountEl.textContent = '0';
      clearError(restaurantError);
      clearError(dateError);
      clearError(guestsError);
      if (summaryPreview) summaryPreview.classList.remove('visible');
    };

  })();
</script>
