<%
  // ============================================================
  // customer/views/restaurants.ejs
  // Lista restaurantelor disponibile pentru client
  // Folosește layout.ejs ca wrapper
  // ============================================================

  const user = locals.user || {};
  const customer = locals.customer || user || {};
%>

<style>
  /* ============================================================
     RESTAURANTS PAGE STYLES
     ============================================================ */
  .restaurants-page .page-intro {
    margin-bottom: 24px;
  }

  .restaurants-page .page-intro h1 {
    font-size: 24px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .restaurants-page .page-intro h1 i {
    color: var(--color-primary);
  }

  .restaurants-page .page-intro p {
    color: var(--color-text-muted);
    margin-top: 4px;
    font-size: 14px;
  }

  .restaurants-search {
    margin-bottom: 24px;
    position: relative;
    max-width: 440px;
  }

  .restaurants-search input {
    width: 100%;
    padding: 12px 16px 12px 44px;
    font-size: 14px;
    font-family: var(--font-family);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-surface);
    color: var(--color-text);
    transition: all 0.2s ease;
  }

  .restaurants-search input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1);
  }

  .restaurants-search i {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    font-size: 15px;
    pointer-events: none;
  }

  .restaurants-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .restaurant-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .restaurant-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary-light);
    transform: translateY(-3px);
  }

  .restaurant-card .card-cover {
    height: 160px;
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .restaurant-card .card-cover i {
    font-size: 52px;
    color: rgba(255,255,255,0.5);
  }

  .restaurant-card .card-cover .restaurant-status {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 4px 12px;
    border-radius: 14px;
    font-size: 11px;
    font-weight: 600;
    background: rgba(0,0,0,0.4);
    color: #fff;
    backdrop-filter: blur(4px);
  }

  .restaurant-card .card-cover .restaurant-status.open {
    background: rgba(46, 125, 50, 0.75);
  }

  .restaurant-card .card-cover .restaurant-status.closed {
    background: rgba(198, 40, 40, 0.75);
  }

  .restaurant-card .card-body {
    padding: 18px 20px;
  }

  .restaurant-card .card-body .restaurant-name {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .restaurant-card .card-body .restaurant-rating {
    font-size: 13px;
    color: #f59e0b;
    display: flex;
    align-items: center;
    gap: 3px;
    white-space: nowrap;
  }

  .restaurant-card .card-body .restaurant-rating span {
    color: var(--color-text-muted);
    font-weight: 500;
    margin-left: 2px;
  }

  .restaurant-card .card-body .restaurant-cuisine {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .restaurant-card .card-body .restaurant-cuisine .tag {
    background: var(--color-bg);
    padding: 2px 10px;
    border-radius: 10px;
    font-weight: 500;
  }

  .restaurant-card .card-body .restaurant-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .restaurant-card .card-body .restaurant-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 12px;
    border-top: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .restaurant-card .card-body .restaurant-footer .info-pill {
    font-size: 12px;
    color: var(--color-text-muted);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .empty-state-r {
    text-align: center;
    padding: 60px 20px;
  }

  .empty-state-r i {
    font-size: 56px;
    opacity: 0.2;
    color: var(--color-text-muted);
    margin-bottom: 16px;
  }

  .empty-state-r h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .empty-state-r p {
    color: var(--color-text-muted);
    font-size: 14px;
    margin-bottom: 20px;
  }

  @media (max-width: 768px) {
    .restaurants-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .restaurants-page .page-intro h1 {
      font-size: 20px;
    }
  }
</style>

<!-- ============================================================
     RESTAURANTS PAGE
     ============================================================ -->
<div class="restaurants-page" data-page="restaurants" data-customer-id="<%= customer._id || '' %>" data-tenant-id="<%= customer.tenantId || '' %>">

  <!-- Page intro -->
  <div class="page-intro">
    <h1>
      <i class="fas fa-store"></i>
      Restaurante
    </h1>
    <p>Descoperă restaurantele disponibile, vezi meniurile și plasează comenzi.</p>
  </div>

  <!-- Search -->
  <div class="restaurants-search">
    <i class="fas fa-search"></i>
    <input type="text" id="restaurantSearch" placeholder="Caută după nume, bucătărie sau adresă…" oninput="filterRestaurants()" />
  </div>

  <!-- Loading -->
  <div id="restLoading" class="spinner"></div>

  <!-- Error -->
  <div id="restError" class="empty-state-r" style="display:none;">
    <i class="fas fa-exclamation-triangle" style="color:var(--color-danger);opacity:0.3;"></i>
    <h3>Eroare la încărcarea restaurantelor</h3>
    <p id="restErrorMsg"></p>
    <button class="btn btn-primary" onclick="loadRestaurants()">
      <i class="fas fa-sync-alt"></i> Reîncearcă
    </button>
  </div>

  <!-- Grid -->
  <div class="restaurants-grid" id="restGrid" style="display:none;"></div>

  <!-- Empty -->
  <div id="restEmpty" class="empty-state-r" style="display:none;">
    <i class="fas fa-store-alt"></i>
    <h3>Niciun restaurant găsit</h3>
    <p id="restEmptyMsg">Nu există restaurante disponibile în acest moment.</p>
  </div>
</div>

<!-- ============================================================
     SCRIPTS
     ============================================================ -->
<script>
  (function() {
    'use strict';

    var tenantId = '<%= customer.tenantId || "" %>';
    var customerId = '<%= customer._id || "" %>';
    var allRestaurants = [];

    // ============================================================
    // Load restaurants
    // ============================================================
    async function loadRestaurants() {
      var loadingEl = document.getElementById('restLoading');
      var errorEl = document.getElementById('restError');
      var gridEl = document.getElementById('restGrid');
      var emptyEl = document.getElementById('restEmpty');

      if (loadingEl) loadingEl.style.display = 'block';
      if (errorEl) errorEl.style.display = 'none';
      if (gridEl) gridEl.style.display = 'none';
      if (emptyEl) emptyEl.style.display = 'none';

      try {
        var data = await apiFetch('/api/restaurants?tenantId=' + tenantId + '&limit=100');
        if (data && data.success && data.data) {
          allRestaurants = data.data.restaurants || [];
        } else {
          allRestaurants = [];
        }
      } catch (err) {
        allRestaurants = [];
      }

      if (loadingEl) loadingEl.style.display = 'none';

      if (!allRestaurants || allRestaurants.length === 0) {
        if (emptyEl) {
          emptyEl.style.display = 'block';
          document.getElementById('restEmptyMsg').textContent = 'Nu există restaurante disponibile momentan.';
        }
        return;
      }

      renderRestaurants(allRestaurants);
    }

    // ============================================================
    // Render restaurants
    // ============================================================
    function renderRestaurants(list) {
      var gridEl = document.getElementById('restGrid');
      var emptyEl = document.getElementById('restEmpty');

      if (!list || list.length === 0) {
        if (gridEl) gridEl.style.display = 'none';
        if (emptyEl) {
          emptyEl.style.display = 'block';
          document.getElementById('restEmptyMsg').textContent = 'Niciun restaurant nu corespunde căutării.';
        }
        return;
      }

      if (emptyEl) emptyEl.style.display = 'none';
      if (gridEl) {
        gridEl.style.display = 'grid';
        gridEl.innerHTML = '';

        list.forEach(function(r) {
          var card = document.createElement('div');
          card.className = 'restaurant-card';
          card.onclick = function() { window.location.href = '/customer/orders/new?restaurantId=' + r._id; };

          var name = r.name || r.nume || 'Restaurant';
          var desc = r.description || r.descriere || '';
          var cuisine = r.cuisine || r.bucatarie || r.tipBucatarie || '';
          var address = r.address || r.adresa || '';
          var rating = r.rating || r.nota || 0;
          var deliveryTime = r.deliveryTime || r.timpLivrare || '30-45 min';
          var minOrder = r.minOrder || r.comandaMinima || 0;
          var isOpen = r.isOpen !== false;

          var cuisineTags = cuisine ? cuisine.split(',').map(function(t) { return t.trim(); }) : [];

          card.innerHTML =
            '<div class="card-cover">' +
              '<i class="fas fa-store-alt"></i>' +
              '<div class="restaurant-status ' + (isOpen ? 'open' : 'closed') + '">' +
                (isOpen ? 'Deschis' : 'Închis') +
              '</div>' +
            '</div>' +
            '<div class="card-body">' +
              '<div class="restaurant-name">' +
                escapeHtml(name) +
                (rating > 0 ? '<span class="restaurant-rating"><i class="fas fa-star"></i> ' + Number(rating).toFixed(1) + ' <span>(' + (r.reviewCount || r.numarReviewuri || 0) + ')</span></span>' : '') +
              '</div>' +
              (cuisineTags.length > 0 ?
                '<div class="restaurant-cuisine">' +
                  cuisineTags.map(function(t) { return '<span class="tag">' + escapeHtml(t) + '</span>'; }).join('') +
                '</div>' : '') +
              (desc ? '<div class="restaurant-desc">' + escapeHtml(desc) + '</div>' : '') +
              '<div class="restaurant-footer">' +
                '<span class="info-pill"><i class="fas fa-map-marker-alt"></i> ' + escapeHtml(address || 'Locație nespecificată') + '</span>' +
                '<span class="info-pill"><i class="fas fa-clock"></i> ' + escapeHtml(deliveryTime) + '</span>' +
                (minOrder > 0 ? '<span class="info-pill"><i class="fas fa-shopping-basket"></i> Min. ' + formatCurrency(minOrder) + '</span>' : '') +
              '</div>' +
            '</div>';

          gridEl.appendChild(card);
        });
      }
    }

    // ============================================================
    // Filter
    // ============================================================
    window.filterRestaurants = function() {
      var query = document.getElementById('restaurantSearch').value.toLowerCase().trim();

      if (!query) {
        renderRestaurants(allRestaurants);
        return;
      }

      var filtered = allRestaurants.filter(function(r) {
        var name = (r.name || r.nume || '').toLowerCase();
        var cuisine = (r.cuisine || r.bucatarie || r.tipBucatarie || '').toLowerCase();
        var address = (r.address || r.adresa || '').toLowerCase();
        var desc = (r.description || r.descriere || '').toLowerCase();

        return name.includes(query) || cuisine.includes(query) || address.includes(query) || desc.includes(query);
      });

      renderRestaurants(filtered);
    };

    // ============================================================
    // Helpers
    // ============================================================
    function escapeHtml(text) {
      if (!text) return '';
      var div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // ============================================================
    // Init
    // ============================================================
    document.addEventListener('DOMContentLoaded', function() {
      loadRestaurants();
    });

    window.loadRestaurants = loadRestaurants;

  })();
</script>
