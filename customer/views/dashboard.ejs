    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.15);
  }
  .dash-mini-list .dash-item .item-dot.pending  {
    background: #f5a623;
    box-shadow: 0 0 0 3px rgba(245, 166, 35, 0.15);
  }
  .dash-mini-list .dash-item .item-dot.info     {
    background: #06b6d4;
    box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
  }
  .dash-mini-list .dash-item .item-dot.muted    {
    background: #9ca3af;
    box-shadow: 0 0 0 3px rgba(156, 163, 175, 0.10);
  }

  .dash-mini-list .dash-item .item-info {
    flex: 1;
    min-width: 0;
  }

  .dash-mini-list .dash-item .item-info .item-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dash-mini-list .dash-item .item-info .item-meta {
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .dash-mini-list .dash-item .item-extra {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
  }

  /* ============================================================
     EMPTY STATE INLINE — Glassmorphism
     ============================================================ */
  .dash-empty-inline {
    text-align: center;
    padding: 36px 16px;
    color: var(--color-text-muted);
  }

  .dash-empty-inline i {
    font-size: 36px;
    opacity: 0.20;
    margin-bottom: 10px;
    color: var(--dash-purple-400);
  }

  .dash-empty-inline p {
    font-size: 13px;
    margin: 0 0 4px;
  }

  .dash-empty-inline .btn-primary {
    background: var(--dash-purple-600);
    border: none;
    box-shadow: 0 4px 14px rgba(124, 58, 237, 0.25);
  }

  .dash-empty-inline .btn-primary:hover {
    background: var(--dash-purple-700);
    box-shadow: 0 6px 20px rgba(124, 58, 237, 0.35);
  }

  /* ============================================================
     USER DATA SUMMARY CARD (sub stats)
     ============================================================ */
  .dash-user-summary {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    box-shadow: var(--glass-shadow);
    padding: 16px 20px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    z-index: 1;
    position: relative;
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .dash-user-summary .summary-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .dash-user-summary .summary-item i {
    color: var(--dash-purple-500);
    font-size: 14px;
    width: 18px;
    text-align: center;
  }

  .dash-user-summary .summary-divider {
    width: 1px;
    height: 18px;
    background: rgba(139, 92, 246, 0.15);
    margin: 0 4px;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 1024px) {
    .dash-stats-row {
      grid-template-columns: 1fr 1fr;
    }

    .quick-links-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .dash-columns {
      grid-template-columns: 1fr;
    }

    .welcome-banner {
      flex-direction: column;
      text-align: center;
      padding: 24px 20px;
    }

    .welcome-banner .welcome-text .welcome-sub {
      justify-content: center;
    }

    .dash-user-summary {
      justify-content: center;
    }

    .dash-user-summary .summary-divider {
      display: none;
    }

    .loyalty-progress-section .loyalty-progress-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .dash-stats-row {
      grid-template-columns: 1fr;
    }

    .quick-links-grid {
      grid-template-columns: 1fr 1fr;
    }

    .welcome-banner .welcome-text h1 {
      font-size: 18px;
    }

    .dash-user-summary {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>

<!-- ============================================================
     CUSTOMER DASHBOARD — PURPLE GLASSMORPHISM
     ============================================================ -->
<div class="customer-dashboard-page" data-page="customer-dashboard">

  <!-- ============================================================
       WELCOME BANNER — Glassmorphism Purple
       ============================================================ -->
  <div class="welcome-banner">
    <div class="welcome-avatar"><%= avatarInitial %></div>
    <div class="welcome-text">
      <h1>
        <i class="fas fa-hand-sparkles"></i>
        Bun venit<%= displayName ? ', ' + displayName : '' %>!
      </h1>
      <div class="welcome-sub">
        <% if (displayName) { %>
          <span>Explorează comenzile, rezervările și ofertele tale.</span>
        <% } else { %>
          <span>Dashboard-ul tău personal. Completează-ți profilul pentru o experiență mai bună.</span>
        <% } %>
        <% if (loyaltyTierLabel) { %>
          <span class="welcome-tier-badge"><%= loyaltyTierLabel %></span>
        <% } %>
        <span class="welcome-date">
          <i class="far fa-calendar-alt"></i>
          <%= new Date().toLocaleDateString('ro-RO', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
        </span>
      </div>
    </div>
  </div>

  <!-- ============================================================
       FETCH ERRORS BANNER (dacă există)
       ============================================================ -->
  <% if (fetchErrors.length > 0) { %>
    <div class="dash-errors-banner">
      <i class="fas fa-exclamation-triangle"></i>
      <span>
        <% fetchErrors.forEach(function(err, idx) { %>
          <%= err %><%= idx < fetchErrors.length - 1 ? ' ' : '' %>
        <% }); %>
      </span>
    </div>
  <% } %>

  <!-- ============================================================
       INCOMPLETE DATA BANNER (date lipsă după login)
       ============================================================ -->
  <% if (hasIncompleteData) { %>
    <div class="dash-incomplete-banner">
      <i class="fas fa-user-edit"></i>
      <span>
        Unele date din profil sunt incomplete (<%= missingFields.join(', ') %>).
        <a href="/customer/profile">Completează profilul</a> pentru o experiență mai bună.
      </span>
    </div>
  <% } %>

  <!-- ============================================================
       USER DATA SUMMARY — Integrare robustă
       ============================================================ -->
  <% if (displayEmail || displayPhone || customerSince) { %>
  <div class="dash-user-summary">
    <% if (displayEmail) { %>
      <span class="summary-item">
        <i class="fas fa-envelope"></i> <%= displayEmail %>
      </span>
    <% } %>
    <% if (displayEmail && displayPhone) { %>
      <span class="summary-divider"></span>
    <% } %>
    <% if (displayPhone) { %>
      <span class="summary-item">
        <i class="fas fa-phone-alt"></i> <%= displayPhone %>
      </span>
    <% } %>
    <% if ((displayEmail || displayPhone) && customerSince) { %>
      <span class="summary-divider"></span>
    <% } %>
    <% if (customerSince) { %>
      <span class="summary-item">
        <i class="fas fa-user-clock"></i>
        Client din <%= safeDate(customerSince, { year: 'numeric', month: 'long' }) %>
      </span>
    <% } %>
  </div>
  <% } %>

  <!-- ============================================================
       STATISTICS ROW
       ============================================================ -->
  <div class="dash-stats-row">
    <!-- Total comenzi recente -->
    <div class="dash-stat">
      <div class="stat-icon-circle orders">
        <i class="fas fa-receipt"></i>
      </div>
      <div class="stat-value"><%= recentOrders.length %></div>
      <div class="stat-label">Comenzi recente</div>
      <div class="stat-hint">
        <% if (pendingOrdersCount > 0) { %>
          <span style="color:var(--dash-purple-600);font-weight:600;"><%= pendingOrdersCount %> în curs</span>
        <% } else { %>
          <span>Nicio comandă activă</span>
        <% } %>
      </div>
    </div>

    <!-- Rezervări active -->
    <div class="dash-stat">
      <div class="stat-icon-circle reserve">
        <i class="fas fa-calendar-check"></i>
      </div>
      <div class="stat-value"><%= activeReservations.length %></div>
      <div class="stat-label">Rezervări active</div>
      <div class="stat-hint">
        <% if (activeReservations.length > 0) { %>
          <span style="color:#059669;font-weight:600;">Confirmate</span>
        <% } else { %>
          <span>Nicio rezervare</span>
        <% } %>
      </div>
    </div>

    <!-- Puncte loialitate -->
    <div class="dash-stat">
      <div class="stat-icon-circle points">
        <i class="fas fa-gem"></i>
      </div>
      <div class="stat-value"><%= loyaltyPoints %></div>
      <div class="stat-label">Puncte loialitate</div>
      <div class="stat-hint">
        <span>Disponibile</span>
        <% if (loyaltyTierLabel) { %>
          · <span style="color:var(--dash-purple-600);font-weight:600;"><%= loyaltyTierLabel %></span>
        <% } %>
      </div>
    </div>

    <!-- Comenzi active (în desfășurare) -->
    <div class="dash-stat">
      <div class="stat-icon-circle active">
        <i class="fas fa-spinner"></i>
      </div>
      <div class="stat-value"><%= pendingOrdersCount %></div>
      <div class="stat-label">În desfășurare</div>
      <div class="stat-hint">
        <span>Comenzi active</span>
      </div>
    </div>
  </div>

  <!-- ============================================================
       LOYALTY PROGRESS — Bară progres spre următorul tier
       ============================================================ -->
  <% if (tierInfo && tierInfo.next) { %>
  <div class="loyalty-progress-section">
    <div class="loyalty-progress-header">
      <span class="loyalty-title">
        <i class="fas fa-crown"></i> Progres loialitate
      </span>
      <span class="loyalty-next">
        <% if (pointsToNextTier > 0) { %>
          Încă <strong><%= pointsToNextTier %></strong> puncte până la <%= tierInfo.label %>
        <% } else { %>
          🎉 Ai atins <%= tierInfo.label %>!
        <% } %>
      </span>
    </div>
    <div class="loyalty-progress-bar-outer">
      <div class="loyalty-progress-bar-inner<%= tierProgressPercent >= 100 ? ' max' : '' %>"
           style="width:<%= tierProgressPercent %>%;"></div>
    </div>
    <div class="loyalty-progress-detail">
      <span><%= loyaltyPoints %> puncte</span>
      <span><%= tierInfo.pointsNeeded %> necesare</span>
    </div>
  </div>
  <% } else if (tierInfo && !tierInfo.next) { %>
  <div class="loyalty-progress-section">
    <div class="loyalty-progress-header">
      <span class="loyalty-title">
        <i class="fas fa-crown"></i> Progres loialitate
      </span>
      <span class="loyalty-next">
        👑 Ai atins nivelul maxim — <strong><%= tierInfo.label %></strong>!
      </span>
    </div>
    <div class="loyalty-progress-bar-outer">
      <div class="loyalty-progress-bar-inner max" style="width:100%;"></div>
    </div>
    <div class="loyalty-progress-detail">
      <span><%= loyaltyPoints %> puncte</span>
      <span>Nivel maxim</span>
    </div>
  </div>
  <% } %>

  <!-- ============================================================
       QUICK LINKS
       ============================================================ -->
  <div class="quick-links-section">
    <h2>
      <i class="fas fa-bolt"></i>
      Acțiuni rapide
    </h2>
    <div class="quick-links-grid">
      <a href="/customer/orders/new" class="quick-link-card">
        <div class="ql-icon"><i class="fas fa-plus-circle"></i></div>
        <div class="ql-label">Comandă nouă</div>
        <div class="ql-desc">Plasează o comandă</div>
      </a>

      <a href="/customer/reservations/new" class="quick-link-card">
        <div class="ql-icon"><i class="fas fa-calendar-plus"></i></div>
        <div class="ql-label">Rezervare nouă</div>
        <div class="ql-desc">Rezervă o masă</div>
      </a>

      <a href="/customer/orders" class="quick-link-card">
        <div class="ql-icon"><i class="fas fa-history"></i></div>
        <div class="ql-label">Istoric comenzi</div>
        <div class="ql-desc">Vezi comenzile tale</div>
      </a>

      <a href="/customer/loyalty" class="quick-link-card">
        <div class="ql-icon"><i class="fas fa-gift"></i></div>
        <div class="ql-label">Loialitate</div>
        <div class="ql-desc">Puncte &amp; cupoane</div>
      </a>

      <a href="/customer/favorites" class="quick-link-card">
        <div class="ql-icon"><i class="fas fa-heart"></i></div>
        <div class="ql-label">Favorite</div>
        <div class="ql-desc">Preparate salvate</div>
      </a>

      <a href="/customer/restaurants" class="quick-link-card">
        <div class="ql-icon"><i class="fas fa-store"></i></div>
        <div class="ql-label">Restaurante</div>
        <div class="ql-desc">Descoperă localuri</div>
      </a>

      <a href="/customer/profile" class="quick-link-card">
        <div class="ql-icon"><i class="fas fa-user-edit"></i></div>
        <div class="ql-label">Profil</div>
        <div class="ql-desc">Editează contul</div>
      </a>

      <a href="/customer/addresses" class="quick-link-card">
        <div class="ql-icon"><i class="fas fa-map-marker-alt"></i></div>
        <div class="ql-label">Adrese</div>
        <div class="ql-desc">Gestionează adresele</div>
      </a>
    </div>
  </div>

  <!-- ============================================================
       TWO-COLUMN: Comenzi recente & Rezervări active
       ============================================================ -->
  <div class="dash-columns">
    <!-- Comenzi recente -->
    <div class="card">
      <div class="card-header">
        <i class="fas fa-receipt" style="color:var(--dash-purple-600);margin-right:8px;"></i>
        Comenzi recente
        <a href="/customer/orders" class="btn btn-sm btn-secondary" style="margin-left:auto;">
          Vezi toate <i class="fas fa-chevron-right" style="font-size:10px;"></i>
        </a>
      </div>
      <div class="card-body">
        <% if (recentOrders.length === 0) { %>
          <div class="dash-empty-inline">
            <i class="fas fa-receipt"></i>
            <p>Nu ai încă nicio comandă.</p>
            <a href="/customer/orders/new" class="btn btn-primary btn-sm mt-2">
              <i class="fas fa-plus"></i> Plasează prima comandă
            </a>
          </div>
        <% } else { %>
          <ul class="dash-mini-list">
            <% recentOrders.forEach(function(order) { %>
              <%
                var dotClass = 'muted';
                var orderStatus = order.status || '';
                if (orderStatus === 'deschisă' || orderStatus === 'processing') dotClass = 'active';
                else if (orderStatus === 'în preparare' || orderStatus === 'preparing') dotClass = 'warning';
                else if (orderStatus === 'finalizată' || orderStatus === 'livrată' || orderStatus === 'achitată' || orderStatus === 'completed' || orderStatus === 'delivered') dotClass = 'success';
                else if (orderStatus === 'anulată' || orderStatus === 'cancelled') dotClass = 'muted';
                else dotClass = 'pending';

                var statusLabels = {
                  'deschisă': 'Deschisă',
                  'în preparare': 'În preparare',
                  'finalizată': 'Finalizată',
                  'livrată': 'Livrată',
                  'achitată': 'Achitată',
                  'anulată': 'Anulată',
                  'processing': 'În procesare',
                  'preparing': 'În preparare',
                  'completed': 'Finalizat',
                  'delivered': 'Livrat',
                  'cancelled': 'Anulat',
                  'pending': 'În așteptare',
                  'confirmed': 'Confirmat'
                };
                var statusLabel = statusLabels[orderStatus] || orderStatus || '—';
                var restaurantName = resolveLocationName(order);
                var orderTotal = Number(order.total) || 0;
                var orderDate = order.createdAt || order.date || '';
                var orderId = safeId(order._id);
                var orderUrl = orderId ? '/customer/orders/' + orderId : '#';
              %>
              <li class="dash-item" style="<%= orderId ? 'cursor:pointer;' : 'cursor:default;opacity:0.6;' %>" <%= orderId ? 'onclick="window.location.href=\'' + orderUrl + '\'"' : '' %>>
                <div class="item-dot <%= dotClass %>"></div>
                <div class="item-info">
                  <div class="item-title"><%= restaurantName %></div>
                  <div class="item-meta">
                    <%= statusLabel %>
                    <% if (orderDate) { %> · <%= safeDate(orderDate, { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' }) %><% } %>
                  </div>
                </div>
                <div class="item-extra"><%= orderTotal.toFixed(2) %> lei</div>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </div>
    </div>

    <!-- Rezervări active -->
    <div class="card">
      <div class="card-header">
        <i class="fas fa-calendar-check" style="color:#059669;margin-right:8px;"></i>
        Rezervări active
        <a href="/customer/reservations" class="btn btn-sm btn-secondary" style="margin-left:auto;">
          Vezi toate <i class="fas fa-chevron-right" style="font-size:10px;"></i>
        </a>
      </div>
      <div class="card-body">
        <% if (activeReservations.length === 0) { %>
          <div class="dash-empty-inline">
            <i class="fas fa-calendar-check"></i>
            <p>Nu ai nicio rezervare activă.</p>
            <a href="/customer/reservations/new" class="btn btn-primary btn-sm mt-2">
              <i class="fas fa-plus"></i> Fă o rezervare
            </a>
          </div>
        <% } else { %>
          <ul class="dash-mini-list">
            <% activeReservations.forEach(function(rez) { %>
              <%
                var rezStatus = rez.status || '';
                var dotClass = 'info';
                if (rezStatus === 'confirmată' || rezStatus === 'confirmed') dotClass = 'success';
                else if (rezStatus === 'check-in') dotClass = 'active';
                else if (rezStatus === 'anulată' || rezStatus === 'cancelled') dotClass = 'muted';

                var rezStatusLabels = {
                  'confirmată': 'Confirmată',
                  'check-in': 'Check-in',
                  'anulată': 'Anulată',
                  'confirmed': 'Confirmată',
                  'cancelled': 'Anulată',
                  'pending': 'În așteptare',
                };
                var rezLabel = rezStatusLabels[rezStatus] || rezStatus || '—';
                var rezDate = rez.data || rez.date || rez.checkInDate || '';
                var rezLocation = resolveLocationName(rez);
                var rezId = safeId(rez._id);
                var rezUrl = rezId ? '/customer/reservations/' + rezId : '#';
              %>
              <li class="dash-item" style="<%= rezId ? 'cursor:pointer;' : 'cursor:default;opacity:0.6;' %>" <%= rezId ? 'onclick="window.location.href=\'' + rezUrl + '\'"' : '' %>>
                <div class="item-dot <%= dotClass %>"></div>
                <div class="item-info">
                  <div class="item-title"><%= rezLocation %></div>
                  <div class="item-meta">
                    <%= rezLabel %>
                    <% if (rezDate) { %> · <%= safeDate(rezDate, { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %><% } %>
                  </div>
                </div>
                <div class="item-extra">
                  <% if (rez.nrPersoane || rez.guests) { %>
                    <i class="fas fa-user-friends" style="font-size:11px;margin-right:2px;"></i>
                    <%= rez.nrPersoane || rez.guests %>
                  <% } %>
                </div>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </div>
    </div>
  </div>

</div>