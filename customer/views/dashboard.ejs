<%
  // ============================================================
  // customer/views/dashboard.ejs
  // Dashboard client — Purple Glassmorphism
  // Folosește layout.ejs ca wrapper
  // ============================================================

  const customer = locals.customer || locals.user || {};
  const recentOrders = locals.recentOrders || [];
  const activeReservations = locals.activeReservations || [];
  const loyaltyPoints = Number(locals.loyaltyPoints) || 0;
  const pendingOrdersCount = Number(locals.pendingOrdersCount) || 0;
  const fetchErrors = locals.fetchErrors || [];

  // ============================================================
  // Helper: formatare sigură a datelor (evită „Invalid Date”)
  // ============================================================
  function safeDate(dateInput, options) {
    if (!dateInput) return '';
    try {
      var d = new Date(dateInput);
      if (isNaN(d.getTime())) return '';
      return d.toLocaleDateString('ro-RO', options);
    } catch (e) {
      return '';
    }
  }

  // ============================================================
  // Helper: escape sigur pentru atribute HTML (onclick etc.)
  // ============================================================
  function safeId(id) {
    if (id === undefined || id === null || id === '') return '';
    return String(id).replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  // ============================================================
  // Helper: nume restaurant/hotel/locație compus
  // ============================================================
  function resolveLocationName(obj) {
    if (!obj) return 'Locație';
    if (obj.restaurantId && obj.restaurantId.name) return obj.restaurantId.name;
    if (obj.hotelId && obj.hotelId.nume) return obj.hotelId.nume;
    if (obj.restaurantName) return obj.restaurantName;
    if (obj.hotelName) return obj.hotelName;
    if (obj.locationName) return obj.locationName;
    return 'Locație';
  }

  // ============================================================
  // Normalizează date utilizator pentru integrare robustă cu userModel
  // Fallback extins pentru customer.nume, customer.email, customer.phone
  // ============================================================

  // --- Nume: compunere din prenume + numeFamilie dacă customer.nume lipsește ---
  const rawFirstName = customer.firstName || customer.prenume || '';
  const rawLastName  = customer.lastName || customer.numeFamilie || customer.familyName || '';
  const composedName = [rawFirstName, rawLastName].filter(Boolean).join(' ');

  const customerNume = customer.nume
    || customer.name
    || composedName
    || customer.displayName
    || customer.username
    || '';

  const customerEmail = customer.email
    || customer.contactEmail
    || customer.emailAddress
    || customer.mail
    || '';

  const customerPhone = customer.telefon
    || customer.phone
    || customer.contactPhone
    || customer.phoneNumber
    || customer.mobile
    || customer.telefonMobil
    || '';

  // Asigură că obiectul customer are câmpurile normalizate (pentru orice referință ulterioară)
  customer.nume  = customerNume || customer.nume || '';
  customer.email = customerEmail || customer.email || '';
  customer.phone = customerPhone || customer.telefon || customer.phone || '';

  // --- Variabile display folosite în template ---
  const displayName = customer.nume
    || customer.name
    || composedName
    || customer.displayName
    || customer.username
    || '';

  const displayEmail = customer.email
    || customer.contactEmail
    || customer.emailAddress
    || customer.mail
    || '';

  const displayPhone = customer.telefon
    || customer.phone
    || customer.contactPhone
    || customer.phoneNumber
    || customer.mobile
    || customer.telefonMobil
    || '';

  const avatarInitial = displayName ? displayName.charAt(0).toUpperCase() : '👤';
  const customerSince = customer.createdAt || customer.joinedAt || customer.dataInregistrare || '';
  const loyaltyTier = customer.loyaltyTier || customer.nivelLoialitate || '';
  const tierLabels = {
    'bronze': '🥉 Bronze',
    'silver': '🥈 Silver',
    'gold': '🥇 Gold',
    'platinum': '💎 Platinum',
    'diamond': '👑 Diamond',
    'bronz': '🥉 Bronz',
    'argint': '🥈 Argint',
    'aur': '🥇 Aur',
    'platina': '💎 Platină',
    'diamant': '👑 Diamant',
  };
  const loyaltyTierLabel = tierLabels[loyaltyTier] || loyaltyTier || '';

  // ============================================================
  // Progres loialitate: cât mai are până la următorul tier
  // ============================================================
  const tierThresholds = {
    'bronze':    { next: 'silver',  pointsNeeded: 500,  label: '🥈 Silver' },
    'silver':    { next: 'gold',    pointsNeeded: 1500, label: '🥇 Gold' },
    'gold':      { next: 'platinum',pointsNeeded: 5000, label: '💎 Platinum' },
    'platinum':  { next: 'diamond', pointsNeeded: 15000,label: '👑 Diamond' },
    'diamond':   { next: null,      pointsNeeded: 0,    label: 'Maxim' },
    'bronz':     { next: 'argint',  pointsNeeded: 500,  label: '🥈 Argint' },
    'argint':    { next: 'aur',     pointsNeeded: 1500, label: '🥇 Aur' },
    'aur':       { next: 'platina', pointsNeeded: 5000, label: '💎 Platină' },
    'platina':   { next: 'diamant', pointsNeeded: 15000,label: '👑 Diamant' },
    'diamant':   { next: null,      pointsNeeded: 0,    label: 'Maxim' },
  };
  var tierInfo = tierThresholds[loyaltyTier] || null;
  var pointsToNextTier = tierInfo ? Math.max(0, tierInfo.pointsNeeded - loyaltyPoints) : 0;
  var tierProgressPercent = tierInfo && tierInfo.pointsNeeded > 0
    ? Math.min(100, Math.round((loyaltyPoints / tierInfo.pointsNeeded) * 100))
    : 100;

  // ============================================================
  // Detectare date incomplete (banner diagnoză)
  // ============================================================
  var hasIncompleteData = !displayName || !displayEmail || !customerSince;
  var missingFields = [];
  if (!displayName) missingFields.push('nume');
  if (!displayEmail) missingFields.push('email');
  if (!customerSince) missingFields.push('data înregistrare');

  // Log silențios pentru diagnoză (doar în development)
  if (locals.dev || locals.debug) {
    console.log('[dashboard.ejs] customer normalized:', {
      nume: displayName || '(lipsă)',
      email: displayEmail || '(lipsă)',
      phone: displayPhone || '(lipsă)',
      tier: loyaltyTierLabel || '(none)',
      points: loyaltyPoints,
      incomplete: hasIncompleteData
    });
  }
%>

<style>
  /* ============================================================
     DASHBOARD CLIENT — Purple Glassmorphism
     Variabile custom pentru glassmorphism mov
     ============================================================ */
  :root {
    --dash-purple-50: #f5f3ff;
    --dash-purple-100: #ede9fe;
    --dash-purple-200: #ddd6fe;
    --dash-purple-300: #c4b5fd;
    --dash-purple-400: #a78bfa;
    --dash-purple-500: #8b5cf6;
    --dash-purple-600: #7c3aed;
    --dash-purple-700: #6d28d9;
    --dash-purple-800: #5b21b6;
    --dash-purple-900: #4c1d95;
    --glass-bg: rgba(255, 255, 255, 0.55);
    --glass-border: rgba(255, 255, 255, 0.65);
    --glass-shadow: 0 8px 32px rgba(124, 58, 237, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    --glass-shadow-hover: 0 16px 40px rgba(124, 58, 237, 0.14), 0 4px 12px rgba(0, 0, 0, 0.06);
    --glass-blur: 14px;
  }

  /* Container principal cu fundal mov subtil */
  .customer-dashboard-page {
    position: relative;
  }

  /* Fundal decorativ — cercuri mov difuze */
