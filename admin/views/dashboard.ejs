  <!-- ============================================================
       SCRIPTS
       ============================================================ -->
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

  <script>
    (function() {
      'use strict';

      // ============================================================
      // STATE
      // ============================================================
      var currentView = 'dashboard';
      var charts = {};
      var refreshTimer = null;

      // ============================================================
      // DOM REFS
      // ============================================================
      var sidebar = document.getElementById('adminSidebar');
      var sidebarToggle = document.getElementById('sidebarToggle');
      var loadingOverlay = document.getElementById('loadingOverlay');
      var toastContainer = document.getElementById('toastContainer');
      var navLinks = document.querySelectorAll('.admin-nav-link');

      // ============================================================
      // SIDEBAR TOGGLE
      // ============================================================
      if (sidebarToggle) {
        sidebarToggle.addEventListener('click', function() {
          sidebar.classList.toggle('open');
        });
      }

      // Close sidebar when clicking outside on mobile
      document.addEventListener('click', function(e) {
        if (window.innerWidth <= 768 &&
            sidebar.classList.contains('open') &&
            !sidebar.contains(e.target) &&
            e.target !== sidebarToggle &&
            !sidebarToggle.contains(e.target)) {
          sidebar.classList.remove('open');
        }
      });

      // ============================================================
      // NAVIGATION
      // ============================================================
      window.adminNavigate = function(view) {
        if (view === currentView) return;

        // Update nav links
        navLinks.forEach(function(link) {
          link.classList.remove('active');
          if (link.getAttribute('data-view') === view) {
            link.classList.add('active');
          }
        });

        // Update views
        document.querySelectorAll('.admin-view').forEach(function(v) {
          v.classList.remove('admin-view--active');
          v.style.display = 'none';
        });

        var targetView = document.getElementById('admin-view-' + view);
        if (targetView) {
          targetView.classList.add('admin-view--active');
          targetView.style.display = 'block';
          currentView = view;

          // Update page title in header
          var pageTitleSpan = document.querySelector('.header .page-title span');
          var pageTitleIcon = document.querySelector('.header .page-title i');
          var titles = {
            dashboard: { icon: 'fa-chart-pie', text: 'Dashboard' },
            tenants:   { icon: 'fa-building', text: 'Tenanți' },
            users:     { icon: 'fa-users-cog', text: 'Utilizatori' },
            audit:     { icon: 'fa-history', text: 'Jurnal Audit' },
            settings:  { icon: 'fa-cog', text: 'Setări Platformă' }
          };

          if (pageTitleIcon && pageTitleSpan && titles[view]) {
            pageTitleIcon.className = 'fas ' + titles[view].icon;
            pageTitleSpan.textContent = titles[view].text;
          }

          // Close sidebar on mobile after navigation
          if (window.innerWidth <= 768) {
            sidebar.classList.remove('open');
          }
        }
      };

      // ============================================================
      // LOADING
      // ============================================================
      function showLoading() {
        if (loadingOverlay) loadingOverlay.classList.add('loading-overlay--active');
      }

      function hideLoading() {
        if (loadingOverlay) loadingOverlay.classList.remove('loading-overlay--active');
      }

      // ============================================================
      // TOAST
      // ============================================================
      window.showToast = function(message, type) {
        type = type || 'info';
        var icons = { success: 'fa-check-circle', error: 'fa-exclamation-circle', warning: 'fa-exclamation-triangle', info: 'fa-info-circle' };
        var toast = document.createElement('div');
        toast.className = 'toast toast-' + type;
        toast.innerHTML = '<i class="fas ' + (icons[type] || icons.info) + '"></i> ' + message;
        if (toastContainer) toastContainer.appendChild(toast);
        setTimeout(function() {
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(100%)';
          toast.style.transition = 'all 0.3s ease';
          setTimeout(function() {
            if (toast.parentNode) toast.parentNode.removeChild(toast);
          }, 300);
        }, 4000);
      };

      // ============================================================
      // FETCH DASHBOARD DATA
      // ============================================================
      function fetchDashboardData() {
        showLoading();
        fetch('/admin/api/dashboard')
          .then(function(res) {
            if (!res.ok) throw new Error('Eroare la încărcarea datelor');
            return res.json();
          })
          .then(function(data) {
            updateDashboardStats(data);
            updateActivityList(data.recentActivity || []);
            updateTopTenants(data.topTenants || []);
            updateCharts(data);
            hideLoading();
          })
          .catch(function(err) {
            console.error('Dashboard fetch error:', err);
            hideLoading();
            window.showToast('Nu s-au putut încărca datele dashboard-ului.', 'error');
            // Use defaults
            updateDashboardStats({});
            updateActivityList([]);
            updateTopTenants([]);
            resetCharts();
          });
      }

      // ============================================================
      // UPDATE STATS
      // ============================================================
      function updateDashboardStats(data) {
        var revenue = data.revenue || 0;
        var tenants = data.tenantCount || data.tenants || 0;
        var users = data.userCount || data.users || 0;
        var locations = data.locationCount || data.locations || 0;
        var subscriptions = data.activeSubscriptions || data.subscriptions || 0;
        var activeTenants = data.activeTenants || tenants;
        var growth = data.growth || '0%';
        var tickets = data.supportTickets || data.tickets || 0;

        setText('admin-stat-revenue', formatCurrency(revenue));
        setText('admin-stat-tenants', tenants);
        setText('admin-stat-users', users);
        setText('admin-stat-locations', locations);
        setText('admin-stat-subscriptions', subscriptions);
        setText('admin-stat-active-tenants', activeTenants);
        setText('admin-stat-growth', growth);
        setText('admin-stat-tickets', tickets);

        // Changes
        var subChange = data.subscriptionChange;
        var tenantChange = data.tenantChange;
        var growthChange = data.growthChange;
        var ticketChange = data.ticketChange;

        if (subChange !== undefined) {
          var subEl = document.getElementById('admin-stat-active-sub-change');
          if (subEl) {
            subEl.textContent = (subChange >= 0 ? '+' : '') + subChange + '%';
            subEl.className = 'stat-change ' + (subChange >= 0 ? 'up' : 'down');
          }
        }
        if (tenantChange !== undefined) {
          var tEl = document.getElementById('admin-stat-tenant-change');
          if (tEl) {
            tEl.textContent = (tenantChange >= 0 ? '+' : '') + tenantChange;
            tEl.className = 'stat-change ' + (tenantChange >= 0 ? 'up' : 'down');
          }
        }
        if (growthChange !== undefined) {
          var gEl = document.getElementById('admin-stat-growth-change');
          if (gEl) {
            gEl.textContent = (growthChange >= 0 ? '+' : '') + growthChange + '%';
            gEl.className = 'stat-change ' + (growthChange >= 0 ? 'up' : 'down');
          }
        }
        if (ticketChange !== undefined) {
          var tkEl = document.getElementById('admin-stat-ticket-change');
          if (tkEl) {
            tkEl.textContent = ticketChange;
            tkEl.className = 'stat-change ' + (ticketChange <= 0 ? 'up' : 'down');
          }
        }
      }

      // ============================================================
      // UPDATE ACTIVITY LIST
      // ============================================================
      function updateActivityList(activities) {
        var container = document.getElementById('activityList');
        var empty = document.getElementById('activity-empty');
        if (!container) return;

        // Remove old items (keep empty state)
        container.querySelectorAll('.activity-item').forEach(function(el) { el.remove(); });

        if (!activities || activities.length === 0) {
          if (empty) empty.classList.remove('d-none');
          return;
        }

        if (empty) empty.classList.add('d-none');

        activities.slice(0, 8).forEach(function(a) {
          var iconClass = a.type || 'info';
          var item = document.createElement('div');
          item.className = 'activity-item';
          item.innerHTML =
            '<div class="activity-icon ' + iconClass + '">' +
              '<i class="fas fa-' + getActivityIcon(iconClass) + '"></i>' +
            '</div>' +
            '<div class="activity-content">' +
              '<div class="activity-text">' + escapeHtml(a.message || a.text || 'Activitate') + '</div>' +
              '<div class="activity-time">' + formatTimeAgo(a.timestamp || a.time) + '</div>' +
            '</div>';
          container.appendChild(item);
        });
      }

      function getActivityIcon(type) {
        var map = { create: 'plus', update: 'pen', delete: 'trash', login: 'sign-in-alt', payment: 'money-bill', warning: 'exclamation-triangle', error: 'times-circle', info: 'info-circle' };
        return map[type] || 'info-circle';
      }

      // ============================================================
      // UPDATE TOP TENANTS
      // ============================================================
      function updateTopTenants(tenants) {
        var container = document.getElementById('topTenantsList');
        var empty = document.getElementById('tenants-empty');
        if (!container) return;

        container.querySelectorAll('.tenant-item').forEach(function(el) { el.remove(); });

        if (!tenants || tenants.length === 0) {
          if (empty) empty.classList.remove('d-none');
          return;
        }

        if (empty) empty.classList.add('d-none');

        tenants.slice(0, 6).forEach(function(t) {
          var item = document.createElement('div');
          item.className = 'tenant-item';
          item.setAttribute('data-tenant-id', t.id || '');
          item.title = 'Vezi detalii ' + escapeHtml(t.name || '');
          item.innerHTML =
            '<div class="tenant-icon"><i class="fas fa-store"></i></div>' +
            '<div class="tenant-info">' +
              '<div class="tenant-name">' + escapeHtml(t.name || 'N/A') + '</div>' +
              '<div class="tenant-meta">' +
                '<span><i class="fas fa-map-marker-alt"></i> ' + (t.locationCount || 0) + ' locații</span>' +
                '<span class="badge ' + (t.active ? 'badge-active' : 'badge-inactive') + '">' + (t.active ? 'Activ' : 'Inactiv') + '</span>' +
              '</div>' +
            '</div>' +
            '<div class="tenant-revenue">' + formatCurrency(t.revenue || 0) + '</div>';
          container.appendChild(item);
        });
      }

      // ============================================================
      // CHARTS
      // ============================================================
      function updateCharts(data) {
        updateRevenueChart(data.revenueChart || data.monthlyRevenue || []);
        updateSubscriptionChart(data.subscriptionChart || data.subscriptionDistribution || []);
      }

      function updateRevenueChart(monthlyData) {
        var canvas = document.getElementById('chartRevenue');
        var empty = document.getElementById('chart-revenue-empty');
        if (!canvas) return;

        if (charts.revenue) {
          charts.revenue.destroy();
          charts.revenue = null;
        }

        var labels = [];
        var values = [];
        if (monthlyData && monthlyData.length > 0) {
          monthlyData.forEach(function(m) {
            labels.push(m.month || m.label || '');
            values.push(m.value || m.amount || 0);
          });
        }

        if (values.length === 0) {
          if (empty) empty.classList.remove('d-none');
          canvas.style.display = 'none';
          return;
        }

        if (empty) empty.classList.add('d-none');
        canvas.style.display = 'block';

        var ctx = canvas.getContext('2d');
        charts.revenue = new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Venituri (RON)',
              data: values,
              borderColor: '#6f42c1',
              backgroundColor: 'rgba(111, 66, 193, 0.08)',
              borderWidth: 2.5,
              fill: true,
              tension: 0.4,
              pointBackgroundColor: '#6f42c1',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              pointRadius: 4,
              pointHoverRadius: 7
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false }
            },
            scales: {
              y: {
                beginAtZero: true,
                grid: { color: 'rgba(111, 66, 193, 0.06)' },
                ticks: { callback: function(v) { return formatCurrency(v); } }
              },
              x: {
                grid: { display: false }
              }
            }
          }
        });
      }

      function updateSubscriptionChart(distribution) {
        var canvas = document.getElementById('chartSubscriptions');
        var empty = document.getElementById('chart-subs-empty');
        if (!canvas) return;

        if (charts.subscriptions) {
          charts.subscriptions.destroy();
          charts.subscriptions = null;
        }

        var labels = [];
        var values = [];
        var colors = ['#6f42c1', '#8b5cf6', '#a78bfa', '#c4b5fd', '#10b981', '#3b82f6'];

        if (distribution && distribution.length > 0) {
          distribution.forEach(function(d, i) {
            labels.push(d.label || d.plan || 'Plan ' + (i + 1));
            values.push(d.value || d.count || 0);
          });
        }

        if (values.length === 0) {
          if (empty) empty.classList.remove('d-none');
          canvas.style.display = 'none';
          return;
        }

        if (empty) empty.classList.add('d-none');
        canvas.style.display = 'block';

        var ctx = canvas.getContext('2d');
        charts.subscriptions = new Chart(ctx, {
          type: 'doughnut',
          data: {
            labels: labels,
            datasets: [{
              data: values,
              backgroundColor: colors.slice(0, values.length),
              borderColor: '#ffffff',
              borderWidth: 3,
              hoverBorderWidth: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: 'bottom',
                labels: {
                  padding: 20,
                  usePointStyle: true
                }
              }
            }
          }
        });
      }

      function resetCharts() {
        Object.keys(charts).forEach(function(key) {
          if (charts[key]) {
            charts[key].destroy();
            charts[key] = null;
          }
        });
        var revCanvas = document.getElementById('chartRevenue');
        var subsCanvas = document.getElementById('chartSubscriptions');
        if (revCanvas) revCanvas.style.display = 'block';
        if (subsCanvas) subsCanvas.style.display = 'block';
        var revEmpty = document.getElementById('chart-revenue-empty');
        var subsEmpty = document.getElementById('chart-subs-empty');
        if (revEmpty) revEmpty.classList.remove('d-none');
        if (subsEmpty) subsEmpty.classList.remove('d-none');
      }

      // ============================================================
      // TENANT FORM
      // ============================================================
      window.showNewTenantForm = function() {
        // Placeholder - can be extended with a modal form
        window.showToast('Formularul pentru tenant nou va fi disponibil în curând.', 'info');
      };

      // ============================================================
      // HELPERS
      // ============================================================
      function setText(id, value) {
        var el = document.getElementById(id);
        if (el) el.textContent = value;
      }

      function formatCurrency(value) {
        var num = parseFloat(value) || 0;
        return num.toLocaleString('ro-RO', { style: 'currency', currency: 'RON', minimumFractionDigits: 0, maximumFractionDigits: 0 });
      }

      function formatTimeAgo(timestamp) {
        if (!timestamp) return 'acum puțin timp';
        var now = new Date();
        var date = new Date(timestamp);
        if (isNaN(date.getTime())) return 'acum puțin timp';
        var diffMs = now - date;
        var diffSec = Math.floor(diffMs / 1000);
        var diffMin = Math.floor(diffSec / 60);
        var diffHour = Math.floor(diffMin / 60);
        var diffDay = Math.floor(diffHour / 24);

        if (diffSec < 60) return 'acum ' + diffSec + ' sec';
        if (diffMin < 60) return 'acum ' + diffMin + ' min';
        if (diffHour < 24) return 'acum ' + diffHour + ' ore';
        if (diffDay < 7) return 'acum ' + diffDay + ' zile';
        return date.toLocaleDateString('ro-RO');
      }

      function escapeHtml(str) {
        if (!str) return '';
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
      }

      // ============================================================
      // SEARCH
      // ============================================================
      var searchInput = document.getElementById('dashboardSearch');
      if (searchInput) {
        searchInput.addEventListener('keydown', function(e) {
          if (e.key === 'Enter') {
            var query = searchInput.value.trim();
            if (query) {
              window.showToast('Căutare pentru: "' + query + '" — funcționalitate în dezvoltare.', 'info');
            }
          }
        });
      }

      // ============================================================
      // AUTO REFRESH (every 60 seconds)
      // ============================================================
      function startAutoRefresh() {
        if (refreshTimer) clearInterval(refreshTimer);
        refreshTimer = setInterval(function() {
          if (currentView === 'dashboard') {
            fetchDashboardData();
          }
        }, 60000);
      }

      // ============================================================
      // INIT
      // ============================================================
      function init() {
        fetchDashboardData();
        startAutoRefresh();
      }

      // Run on DOM ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</body>
</html>