    }

    .inv-dash-table .inv-supplier-cell {
      display: none;
    }
  }
</style>

<!-- ============================================================
     DASHBOARD HEADER
     ============================================================ -->
<div class="dashboard-header">
  <div>
    <h1>
      <i class="fas fa-th-large" style="color:var(--color-primary);margin-right:8px;"></i>
      Dashboard
    </h1>
    <div class="header-meta">
      <% if (restaurant) { %>
        <span class="resto-name"><i class="fas fa-store"></i> <%= restaurant.name %></span>
        <span class="text-muted">•</span>
      <% } %>
      <span class="date-badge">
        <i class="far fa-calendar-alt"></i>
        <%= new Date().toLocaleDateString('ro-RO', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
      </span>
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;">
    <a href="/restaurant/orders/new" class="btn btn-primary btn-sm">
      <i class="fas fa-plus"></i> Comandă nouă
    </a>
    <button class="btn btn-secondary btn-sm" onclick="refreshDashboard()">
      <i class="fas fa-sync-alt"></i> Reîmprospătare
    </button>
  </div>
</div>

<!-- ============================================================
     LOADING OVERLAY
     ============================================================ -->
<% if (loading) { %>
  <div class="spinner"></div>
<% } else { %>

<!-- ============================================================
     ALERTS
     ============================================================ -->
<% if (locals.alert) { %>
  <div class="dashboard-alert <%= alert.type || 'info' %>">
    <i class="fas fa-<%= alert.type === 'warning' ? 'exclamation-triangle' : alert.type === 'success' ? 'check-circle' : 'info-circle' %>"></i>
    <%= alert.message %>
  </div>
<% } %>

<!-- ============================================================
     STATISTICS CARDS
     ============================================================ -->
<div class="stats-grid">
  <!-- Total comenzi azi -->
  <div class="stat-card orders">
    <div class="stat-icon"><i class="fas fa-receipt"></i></div>
    <div class="stat-label">Comenzi azi</div>
    <div class="stat-value"><%= stats.ordersToday || 0 %></div>
    <% if (stats.ordersTrend !== undefined) { %>
      <span class="stat-change <%= stats.ordersTrend > 0 ? 'up' : stats.ordersTrend < 0 ? 'down' : 'neutral' %>">
        <i class="fas fa-<%= stats.ordersTrend > 0 ? 'arrow-up' : stats.ordersTrend < 0 ? 'arrow-down' : 'minus' %>"></i>
        <%= Math.abs(stats.ordersTrend) %>%
      </span>
    <% } %>
  </div>

  <!-- Venituri azi -->
  <div class="stat-card revenue">
    <div class="stat-icon"><i class="fas fa-money-bill-wave"></i></div>
    <div class="stat-label">Venituri azi</div>
    <div class="stat-value"><%= stats.revenueToday ? stats.revenueToday.toFixed(2) : '0.00' %> lei</div>
    <% if (stats.revenueTrend !== undefined) { %>
      <span class="stat-change <%= stats.revenueTrend > 0 ? 'up' : stats.revenueTrend < 0 ? 'down' : 'neutral' %>">
        <i class="fas fa-<%= stats.revenueTrend > 0 ? 'arrow-up' : stats.revenueTrend < 0 ? 'arrow-down' : 'minus' %>"></i>
        <%= Math.abs(stats.revenueTrend) %>%
      </span>
    <% } %>
  </div>

  <!-- Comenzi active -->
  <div class="stat-card active">
    <div class="stat-icon"><i class="fas fa-spinner"></i></div>
    <div class="stat-label">Active</div>
    <div class="stat-value"><%= stats.activeOrders || 0 %></div>
    <span class="stat-change neutral">
      <i class="fas fa-clock"></i> În desfășurare
    </span>
  </div>

  <!-- Mese ocupate -->
  <div class="stat-card tables">
    <div class="stat-icon"><i class="fas fa-chair"></i></div>
    <div class="stat-label">Mese ocupate</div>
    <div class="stat-value"><%= stats.occupiedTables || 0 %> / <%= stats.totalTables || 0 %></div>
    <% if (stats.occupancyPercent !== undefined) { %>
      <span class="stat-change <%= stats.occupancyPercent > 70 ? 'up' : stats.occupancyPercent > 40 ? 'neutral' : 'down' %>">
        <%= stats.occupancyPercent %>%
      </span>
    <% } %>
  </div>
</div>

<!-- ============================================================
     DASHBOARD THREE COLUMNS: Orders / Inventory / Suppliers
     ============================================================ -->
<div class="dashboard-columns-3">

  <!-- ============================================================
       LEFT COLUMN: Active Orders
       ============================================================ -->
  <div class="section-card">
    <div class="section-header">
      <h2>
        <i class="fas fa-bolt"></i>
        Comenzi active
        <span class="badge badge-active" style="margin-left:8px;"><%= activeOrders.length %></span>
      </h2>
      <div class="section-actions">
        <a href="/restaurant/orders?status=deschisă" class="btn btn-sm btn-secondary">
          Vezi toate <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    </div>
    <div class="section-body">
      <% if (activeOrders.length === 0) { %>
        <div class="empty-orders">
          <i class="fas fa-check-circle" style="color:var(--color-success);opacity:0.5;"></i>
          <p>Toate comenzile sunt finalizate. <strong>Excelent!</strong></p>
        </div>
      <% } else { %>
        <ul class="order-list">
          <% activeOrders.forEach(function(order) { %>
            <li class="order-item" onclick="window.location.href='/restaurant/orders/<%= order._id %>'" title="Vezi comanda">
              <div class="order-table <%= order.masa > 0 ? 'active-table' : '' %>">
                <%= order.masa > 0 ? 'M' + order.masa : '★' %>
              </div>
              <div class="order-info">
                <div class="order-meta">
                  <span class="order-id"><%= order._id.substring(0, 8) %>...</span>
                  <span class="badge <%= order.status === 'deschisă' ? 'badge-active' : order.status === 'în preparare' ? '' : 'badge-info' %>" 
                        style="<%= order.status === 'în preparare' ? 'background:#fff8e1;color:#f57f17;' : '' %>">
                    <%= order.status %>
                  </span>
                  <span class="order-time">
                    <i class="far fa-clock"></i> 
                    <%= formatDate(order.createdAt) %>
                  </span>
                </div>
                <div class="order-items-preview">
                  <% if (order.articole && order.articole.length > 0) { %>
                    <%= order.articole.map(function(a) { return a.cantitate + 'x ' + a.nume; }).join(', ') %>
                  <% } else { %>
                    <em>Fără articole</em>
                  <% } %>
                </div>
                <% if (order.ospatar) { %>
                  <div class="order-waiter">
                    <i class="fas fa-user-tie"></i> <%= order.ospatar %>
                  </div>
                <% } %>
              </div>
              <div class="order-total">
                <%= formatCurrency(order.total || 0) %>
              </div>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </div>
    <% if (activeOrders.length > 5) { %>
      <div class="section-footer">
        <a href="/restaurant/orders?status=deschisă" class="btn btn-sm btn-secondary">
          Vezi toate cele <%= activeOrders.length %> comenzi active <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    <% } %>
  </div>

  <!-- ============================================================
       MIDDLE COLUMN: Inventory Section with Table,