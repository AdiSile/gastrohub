<%
  // Variabile locale
  const stats = locals.stats || {};
  const activeOrders = locals.activeOrders || [];
  const recentOrders = locals.recentOrders || [];
  const restaurant = locals.restaurant || null;
  const loading = locals.loading || false;

  // Inventar
  const inventoryItems = locals.inventoryItems || [];
  const lowStockItems = locals.lowStockItems || [];

  // Furnizori și comenzi furnizori
  const suppliers = locals.suppliers || [];
  const recentSupplierOrders = locals.recentSupplierOrders || [];

  // Prag minim pentru alertă inventar
  const INVENTORY_MIN_THRESHOLD = 5;

  // Helpers
  function getSupplierName(supplierId) {
    if (!supplierId || !suppliers.length) return '';
    const match = suppliers.find(function(s) { return s._id === supplierId; });
    return match ? match.name : '';
  }

  function getMinThreshold(item) {
    return item.minThreshold || item.minThreshold === 0 ? item.minThreshold : INVENTORY_MIN_THRESHOLD;
  }

  function getQtyClass(item) {
    var qty = item.quantity || 0;
    var threshold = getMinThreshold(item);
    if (qty === 0) return 'critical';
    if (qty < threshold) return 'low';
    return 'ok';
  }
%>

