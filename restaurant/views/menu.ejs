<%
  // Variabile locale
  const restaurant = locals.restaurant || null;
  const categories = locals.categories || [];
  const menuItems = locals.menuItems || [];
  const loading = locals.loading || false;
  const currentCategory = locals.currentCategory || null;
%>

<style>
  /* ============================================================
     MENU STYLES
     ============================================================ */
  .menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .menu-header h1 {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .menu-header h1 i {
    color: var(--color-primary);
  }

  .menu-header .header-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--color-text-muted);
    font-size: 13px;
  }

  .menu-header .header-meta .resto-name {
    font-weight: 600;
    color: var(--color-primary);
  }

  /* ============================================================
     CATEGORY TABS
     ============================================================ */
  .category-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border);
  }

  .category-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    text-decoration: none;
  }

  .category-tab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .category-tab.active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .category-tab .count {
    background: rgba(0,0,0,0.08);
    border-radius: 12px;
    padding: 1px 8px;
    font-size: 11px;
    font-weight: 600;
  }

  .category-tab.active .count {
    background: rgba(255,255,255,0.25);
    color: #fff;
  }

  .category-tab.add-category {
    border-style: dashed;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .category-tab.add-category:hover {
    border-color: var(--color-success);
    color: var(--color-success);
  }

  /* ============================================================
     MENU ITEMS GRID
     ============================================================ */
  .menu-items-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 28px;
  }

  @media (max-width: 480px) {
    .menu-items-grid {
      grid-template-columns: 1fr;
    }
  }

  .menu-item-card {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: all var(--transition);
    position: relative;
  }

  .menu-item-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .menu-item-card .item-image {
    width: 100%;
    height: 140px;
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 36px;
    position: relative;
    overflow: hidden;
  }

  .menu-item-card .item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .menu-item-card .item-image .no-image {
    opacity: 0.2;
  }

  .menu-item-card .item-image .availability-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 12px;
  }

  .menu-item-card .item-image .availability-badge.available {
    background: rgba(39, 174, 96, 0.9);
    color: #fff;
  }

  .menu-item-card .item-image .availability-badge.unavailable {
    background: rgba(231, 76, 60, 0.9);
    color: #fff;
  }

  .menu-item-card .item-image .availability-badge.seasonal {
    background: rgba(243, 156, 18, 0.9);
    color: #fff;
  }

  .menu-item-card .item-image .availability-badge.temporary {
    background: rgba(52, 152, 219, 0.9);
    color: #fff;
  }

  .menu-item-card .item-body {
    padding: 14px 16px;
  }

  .menu-item-card .item-body .item-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .menu-item-card .item-body .item-name .item-category {
    font-size: 11px;
    font-weight: 400;
    color: var(--color-text-muted);
    background: var(--color-bg);
    padding: 1px 8px;
    border-radius: 10px;
  }

  .menu-item-card .item-body .item-description {
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .menu-item-card .item-body .item-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  .menu-item-card .item-body .item-meta .item-price {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-primary);
  }

  .menu-item-card .item-body .item-meta .item-allergens {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .menu-item-card .item-body .item-meta .item-allergens .allergen {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #fff8e1;
    color: #f57f17;
    font-size: 10px;
    font-weight: 700;
    cursor: help;
    border: 1px solid #ffe0b2;
  }

  .menu-item-card .item-body .item-ingredients {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 8px;
  }

  .menu-item-card .item-body .item-ingredients .ingredient {
    font-size: 11px;
    color: var(--color-text-muted);
    background: var(--color-bg);
    padding: 2px 8px;
    border-radius: 8px;
  }

  .menu-item-card .item-actions {
    display: flex;
    border-top: 1px solid var(--color-border);
  }

  .menu-item-card .item-actions button {
    flex: 1;
    padding: 10px;
    border: none;
    background: none;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }

  .menu-item-card .item-actions button:hover {
    background: rgba(0,0,0,0.02);
  }

  .menu-item-card .item-actions button.edit-btn:hover {
    color: var(--color-info);
  }

  .menu-item-card .item-actions button.toggle-btn:hover {
    color: var(--color-warning);
  }

  .menu-item-card .item-actions button.delete-btn:hover {
    color: var(--color-danger);
  }

  .menu-item-card .item-actions button + button {
    border-left: 1px solid var(--color-border);
  }

  /* ============================================================
     EMPTY STATE
     ============================================================ */
  .empty-menu {
    text-align: center;
    padding: 60px 20px;
    color: var(--color-text-muted);
  }

  .empty-menu i {
    font-size: 56px;
    opacity: 0.2;
    margin-bottom: 16px;
  }

  .empty-menu h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .empty-menu p {
    font-size: 14px;
    margin-bottom: 20px;
  }

  /* ============================================================
     MODAL FORM
     ============================================================ */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .form-row-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 14px;
  }

  @media (max-width: 480px) {
    .form-row, .form-row-3 {
      grid-template-columns: 1fr;
    }
  }

  .form-group .checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .form-group .checkbox-group label {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    font-weight: 400;
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all var(--transition);
  }

  .form-group .checkbox-group label:hover {
    border-color: var(--color-primary);
  }

  .form-group .checkbox-group input[type="checkbox"] {
    width: auto;
    margin: 0;
  }

  .form-group .checkbox-group input[type="checkbox"]:checked + span {
    color: var(--color-primary);
    font-weight: 600;
  }

  .form-group .checkbox-group label:has(input:checked) {
    border-color: var(--color-primary);
    background: rgba(232, 93, 4, 0.06);
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 768px) {
    .menu-items-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .menu-items-grid {
      grid-template-columns: 1fr;
    }

    .menu-header h1 {
      font-size: 20px;
    }
  }
</style>

<!-- ============================================================
     MENU HEADER
     ============================================================ -->
<div class="menu-header">
  <div>
    <h1>
      <i class="fas fa-utensils"></i>
      Meniu Digital
    </h1>
    <div class="header-meta">
      <% if (restaurant) { %>
        <span class="resto-name"><i class="fas fa-store"></i> <%= restaurant.name %></span>
        <span class="text-muted">•</span>
      <% } %>
      <span>
        <i class="fas fa-layer-group"></i>
        <%= categories.length %> categorii
      </span>
      <span>
        <i class="fas fa-box"></i>
        <%= menuItems.length %> produse
      </span>
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;">
    <button class="btn btn-primary btn-sm" onclick="openAddItemModal()">
      <i class="fas fa-plus"></i> Produs nou
    </button>
    <button class="btn btn-secondary btn-sm" onclick="openAddCategoryModal()">
      <i class="fas fa-folder-plus"></i> Categorie nouă
    </button>
  </div>
</div>

<!-- ============================================================
     LOADING
     ============================================================ -->
<% if (loading) { %>
  <div class="spinner"></div>
<% } else { %>

<!-- ============================================================
     ALERT
     ============================================================ -->
<% if (locals.alert) { %>
  <div class="dashboard-alert <%= alert.type || 'info' %>" style="margin-bottom:20px;">
    <i class="fas fa-<%= alert.type === 'warning' ? 'exclamation-triangle' : alert.type === 'success' ? 'check-circle' : 'info-circle' %>"></i>
    <%= alert.message %>
  </div>
<% } %>

<!-- ============================================================
     CATEGORY TABS
     ============================================================ -->
<div class="category-tabs">
  <a href="?category=all" class="category-tab <%= !currentCategory || currentCategory === 'all' ? 'active' : '' %>">
    <i class="fas fa-th-list"></i> Toate
    <span class="count"><%= menuItems.length %></span>
  </a>

  <% categories.forEach(function(cat) { %>
    <% 
      var catCount = menuItems.filter(function(item) {
        return item.category === cat;
      }).length;
    %>
    <a href="?category=<%= encodeURIComponent(cat) %>" class="category-tab <%= currentCategory === cat ? 'active' : '' %>">
      <i class="fas fa-tag"></i> <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
      <span class="count"><%= catCount %></span>
    </a>
  <% }); %>

  <a href="#" class="category-tab add-category" onclick="event.preventDefault();openAddCategoryModal();">
    <i class="fas fa-plus"></i> Categorie
  </a>
</div>

<!-- ============================================================
     MENU ITEMS
     ============================================================ -->
<% if (menuItems.length === 0) { %>
  <div class="empty-menu">
    <i class="fas fa-utensils"></i>
    <h3>Nu există produse în meniu</h3>
    <p>Adaugă primul produs pentru a începe să construiești meniul digital.</p>
    <button class="btn btn-primary" onclick="openAddItemModal()">
      <i class="fas fa-plus"></i> Adaugă produs
    </button>
  </div>
<% } else { %>
  <div class="menu-items-grid">
    <% 
      var filteredItems = menuItems;
      if (currentCategory && currentCategory !== 'all') {
        filteredItems = menuItems.filter(function(item) {
          return item.category === currentCategory;
        });
      }
    %>

    <% filteredItems.forEach(function(item) { %>
      <div class="menu-item-card" data-id="<%= item._id %>" data-category="<%= item.category %>">
        <!-- Image -->
        <div class="item-image">
          <% if (item.imageUrl) { %>
            <img src="<%= item.imageUrl %>" alt="<%= item.name %>" loading="lazy" />
          <% } else { %>
            <div class="no-image"><i class="fas fa-image"></i></div>
          <% } %>

          <span class="availability-badge <%= item.availability || 'available' %>">
            <%= item.availability === 'available' ? 'Disponibil' : 
                item.availability === 'unavailable' ? 'Indisponibil' : 
                item.availability === 'seasonal' ? 'Sezonier' : 'Temporar' %>
          </span>
        </div>

        <!-- Body -->
        <div class="item-body">
          <div class="item-name">
            <%= item.name %>
            <span class="item-category"><%= item.category %></span>
          </div>

          <% if (item.description) { %>
            <div class="item-description"><%= item.description %></div>
          <% } %>

          <!-- Allergens -->
          <% if (item.allergens && item.allergens.length > 0) { %>
            <div class="item-allergens" style="margin-bottom:6px;">
              <% item.allergens.forEach(function(allergen) { %>
                <span class="allergen" title="<%= allergen %>">
                  <%= allergen.substring(0, 2).toUpperCase() %>
                </span>
              <% }); %>
            </div>
          <% } %>

          <!-- Ingredients -->
          <% if (item.ingredients && item.ingredients.length > 0) { %>
            <div class="item-ingredients">
              <% item.ingredients.forEach(function(ing) { %>
                <span class="ingredient"><%= ing %></span>
              <% }); %>
            </div>
          <% } %>

          <!-- Price -->
          <div class="item-meta" style="margin-top:8px;">
            <div class="item-price"><%= Number(item.price).toFixed(2) %> lei</div>
            <div style="font-size:11px;color:var(--color-text-muted);">
              <i class="far fa-clock"></i> 
              <%= item.updatedAt ? formatDate(item.updatedAt) : '—' %>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="item-actions">
          <button class="edit-btn" onclick="openEditItemModal('<%= item._id %>')">
            <i class="fas fa-edit"></i> Editează
          </button>
          <button class="toggle-btn" onclick="toggleItemAvailability('<%= item._id %>', '<%= item.availability %>')">
            <i class="fas fa-<%= item.availability === 'available' ? 'eye-slash' : 'eye' %>"></i>
            <%= item.availability === 'available' ? 'Ascunde' : 'Arată' %>
          </button>
          <button class="delete-btn" onclick="deleteMenuItem('<%= item._id %>', '<%= item.name.replace(/'/g, "\\'") %>')">
            <i class="fas fa-trash"></i> Șterge
          </button>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<% } /* end loading */ %>

<!-- ============================================================
     MODAL: Add / Edit Item
     ============================================================ -->
<div id="itemModal" class="modal-overlay" style="display:none;">
  <div class="modal">
    <div class="modal-header">
      <h2 id="itemModalTitle">Adaugă produs nou</h2>
      <button class="modal-close" onclick="closeItemModal()">&times;</button>
    </div>
    <div class="modal-body">
      <form id="itemForm" onsubmit="return saveItem(event)">
        <input type="hidden" id="itemId" value="" />

        <div class="form-row">
          <div class="form-group">
            <label for="itemName">Nume produs *</label>
            <input type="text" id="itemName" required maxlength="200" placeholder="Ex: Pizza Margherita" />
          </div>
          <div class="form-group">
            <label for="itemCategory">Categorie *</label>
            <select id="itemCategory" required>
              <option value="">— Selectează categoria —</option>
              <% var allCats = ['aperitiv','fel principal','desert','băuturi','gustări','salate','supe/ciorbă','paste','pizza','pește','carne','vegetarian','vegan','mic dejun','brunch','cină','bar','cocktail','vinuri','bere','cafea','alte']; %>
              <% allCats.forEach(function(cat) { %>
                <option value="<%= cat %>"><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></option>
              <% }); %>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="itemDescription">Descriere</label>
          <textarea id="itemDescription" rows="3" maxlength="2000" placeholder="Descrie produsul..."></textarea>
        </div>

        <div class="form-row-3">
          <div class="form-group">
            <label for="itemPrice">Preț (lei) *</label>
            <input type="number" id="itemPrice" required min="0" step="0.01" placeholder="0.00" />
          </div>
          <div class="form-group">
            <label for="itemAvailability">Disponibilitate</label>
            <select id="itemAvailability">
              <option value="available">Disponibil</option>
              <option value="unavailable">Indisponibil</option>
              <option value="seasonal">Sezonier</option>
              <option value="temporary">Temporar</option>
            </select>
          </div>
          <div class="form-group">
            <label for="itemImageUrl">URL Imagine</label>
            <input type="url" id="itemImageUrl" placeholder="https://..." />
          </div>
        </div>

        <div class="form-group">
          <label>Alergeni</label>
          <div class="checkbox-group" id="allergensGroup">
            <% var allAllergens = ['lactoză','ouă','arahide','nuci','migdale','alune','soia','gluten','crustacee','pește','sulfiți','susan','țelină','muștar','lupin','moluște']; %>
            <% allAllergens.forEach(function(a) { %>
              <label>
                <input type="checkbox" value="<%= a %>" class="allergen-cb" />
                <span><%= a.charAt(0).toUpperCase() + a.slice(1) %></span>
              </label>
            <% }); %>
          </div>
        </div>

        <div class="form-group">
          <label for="itemIngredients">Ingrediente (separate prin virgulă)</label>
          <input type="text" id="itemIngredients" placeholder="Ex: roșii, mozzarella, busuioc" />
        </div>

        <div class="form-actions">
          <button type="button" class="btn btn-secondary" onclick="closeItemModal()">Anulează</button>
          <button type="submit" class="btn btn-primary" id="itemSubmitBtn">
            <i class="fas fa-save"></i> Salvează
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: Add Category (simple prompt)
     ============================================================ -->
<div id="categoryModal" class="modal-overlay" style="display:none;">
  <div class="modal" style="max-width:400px;">
    <div class="modal-header">
      <h2>Categorie nouă</h2>
      <button class="modal-close" onclick="closeCategoryModal()">&times;</button>
    </div>
    <div class="modal-body">
      <form id="categoryForm" onsubmit="return addCategory(event)">
        <div class="form-group">
          <label for="categoryName">Nume categorie *</label>
          <input type="text" id="categoryName" required maxlength="50" 
                 placeholder="Ex: mic dejun, brunch, bar" 
                 list="categorySuggestions" />
          <datalist id="categorySuggestions">
            <% allCats.forEach(function(cat) { %>
              <option value="<%= cat %>">
            <% }); %>
          </datalist>
          <div class="form-error" id="categoryError" style="display:none;"></div>
        </div>
        <div class="form-actions">
          <button type="button" class="btn btn-secondary" onclick="closeCategoryModal()">Anulează</button>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-plus"></i> Adaugă
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ============================================================
     SCRIPTS
     ============================================================ -->
<script>
  (function() {
    // ----------------------------------------------------------
    // State
    // ----------------------------------------------------------
    var currentRestaurantId = '<%= restaurant ? restaurant._id : "" %>';

    // ----------------------------------------------------------
    // Modal helpers
    // ----------------------------------------------------------
    function showModal(modalId) {
      var modal = document.getElementById(modalId);
      if (modal) modal.style.display = 'flex';
    }

    function hideModal(modalId) {
      var modal = document.getElementById(modalId);
      if (modal) modal.style.display = 'none';
    }

    // ----------------------------------------------------------
    // Open Add Item Modal
    // ----------------------------------------------------------
    window.openAddItemModal = function() {
      // Reset form
      document.getElementById('itemForm').reset();
      document.getElementById('itemId').value = '';
      document.getElementById('itemModalTitle').textContent = 'Adaugă produs nou';
      document.getElementById('itemSubmitBtn').innerHTML = '<i class="fas fa-save"></i> Salvează';

      // Pre-select category if filtering
      var urlParams = new URLSearchParams(window.location.search);
      var catParam = urlParams.get('category');
      if (catParam && catParam !== 'all') {
        document.getElementById('itemCategory').value = catParam;
      }

      // Uncheck all allergens
      document.querySelectorAll('.allergen-cb').forEach(function(cb) {
        cb.checked = false;
      });

      showModal('itemModal');
    };

    // ----------------------------------------------------------
    // Open Edit Item Modal
    // ----------------------------------------------------------
    window.openEditItemModal = function(itemId) {
      if (!itemId) return;

      var card = document.querySelector('.menu-item-card[data-id="' + itemId + '"]');
      if (!card) {
        showToast('Produsul nu a fost găsit.', 'error');
        return;
      }

      // We need to fetch item data from API
      apiFetch('/api/menu/' + itemId)
        .then(function(result) {
          if (!result || !result.data || !result.data.item) {
            showToast('Nu s-au putut încărca datele produsului.', 'error');
            return;
          }

          var item = result.data.item;

          document.getElementById('itemId').value = item._id;
          document.getElementById('itemModalTitle').textContent = 'Editează: ' + item.name;
          document.getElementById('itemSubmitBtn').innerHTML = '<i class="fas fa-save"></i> Actualizează';
          document.getElementById('itemName').value = item.name || '';
          document.getElementById('itemCategory').value = item.category || '';
          document.getElementById('itemDescription').value = item.description || '';
          document.getElementById('itemPrice').value = item.price || '';
          document.getElementById('itemAvailability').value = item.availability || 'available';
          document.getElementById('itemImageUrl').value = item.imageUrl || '';
          document.getElementById('itemIngredients').value = (item.ingredients || []).join(', ');

          // Allergens
          document.querySelectorAll('.allergen-cb').forEach(function(cb) {
            cb.checked = (item.allergens || []).includes(cb.value);
          });

          showModal('itemModal');
        })
        .catch(function(err) {
          showToast('Eroare la încărcarea produsului: ' + err.message, 'error');
        });
    };

    // ----------------------------------------------------------
    // Close Item Modal
    // ----------------------------------------------------------
    window.closeItemModal = function() {
      hideModal('itemModal');
    };

    // ----------------------------------------------------------
    // Save Item (Create / Update)
    // ----------------------------------------------------------
    window.saveItem = function(event) {
      event.preventDefault();

      var itemId = document.getElementById('itemId').value;
      var isEdit = !!itemId;

      var data = {
        name: document.getElementById('itemName').value.trim(),
        category: document.getElementById('itemCategory').value,
        price: parseFloat(document.getElementById('itemPrice').value),
        description: document.getElementById('itemDescription').value.trim(),
        availability: document.getElementById('itemAvailability').value,
        imageUrl: document.getElementById('itemImageUrl').value.trim(),
        ingredients: document.getElementById('itemIngredients').value.split(',').map(function(s) { return s.trim(); }).filter(Boolean),
        allergens: Array.from(document.querySelectorAll('.allergen-cb:checked')).map(function(cb) { return cb.value; }),
        restaurantId: currentRestaurantId,
      };

      // Validate
      if (!data.name) { showToast('Numele produsului este obligatoriu.', 'error'); return; }
      if (!data.category) { showToast('Categoria este obligatorie.', 'error'); return; }
      if (isNaN(data.price) || data.price < 0) { showToast('Prețul trebuie să fie un număr pozitiv.', 'error'); return; }
      if (!currentRestaurantId) { showToast('Nu există un restaurant selectat.', 'error'); return; }

      var method = isEdit ? 'PUT' : 'POST';
      var url = isEdit ? '/api/menu/' + itemId : '/api/menu';

      // Disable button
      var btn = document.getElementById('itemSubmitBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Se salvează...';

      apiFetch(url, {
        method: method,
        body: JSON.stringify(data),
      })
      .then(function(result) {
        if (result) {
          showToast(isEdit ? 'Produs actualizat cu succes!' : 'Produs creat cu succes!', 'success');
          closeItemModal();
          // Refresh page to show changes
          setTimeout(function() { window.location.reload(); }, 1000);
        }
      })
      .catch(function(err) {
        showToast('Eroare la salvarea produsului: ' + err.message, 'error');
      })
      .finally(function() {
        btn.disabled = false;
        btn.innerHTML = isEdit ? '<i class="fas fa-save"></i> Actualizează' : '<i class="fas fa-save"></i> Salvează';
      });

      return false;
    };

    // ----------------------------------------------------------
    // Toggle Item Availability
    // ----------------------------------------------------------
    window.toggleItemAvailability = function(itemId, currentAvailability) {
      if (!itemId) return;

      var newAvailability = currentAvailability === 'available' ? 'unavailable' : 'available';
      var actionLabel = newAvailability === 'available' ? 'activare' : 'dezactivare';

      if (!confirm('Ești sigur că vrei să ' + actionLabel + ' acest produs?')) return;

      apiFetch('/api/menu/' + itemId + '/availability', {
        method: 'PATCH',
        body: JSON.stringify({ availability: newAvailability }),
      })
      .then(function(result) {
        if (result) {
          showToast('Disponibilitatea a fost actualizată!', 'success');
          setTimeout(function() { window.location.reload(); }, 500);
        }
      })
      .catch(function(err) {
        showToast('Eroare la actualizare: ' + err.message, 'error');
      });
    };

    // ----------------------------------------------------------
    // Delete Menu Item
    // ----------------------------------------------------------
    window.deleteMenuItem = function(itemId, itemName) {
      if (!itemId) return;

      if (!confirm('Ești sigur că vrei să ștergi "' + itemName + '"? Această acțiune este ireversibilă.')) return;

      apiFetch('/api/menu/' + itemId, {
        method: 'DELETE',
      })
      .then(function(result) {
        if (result) {
          showToast('Produsul "' + itemName + '" a fost șters.', 'success');
          // Remove card from DOM
          var card = document.querySelector('.menu-item-card[data-id="' + itemId + '"]');
          if (card) card.remove();
          // If no items left, reload to show empty state
          if (document.querySelectorAll('.menu-item-card').length === 0) {
            setTimeout(function() { window.location.reload(); }, 500);
          }
        }
      })
      .catch(function(err) {
        showToast('Eroare la ștergere: ' + err.message, 'error');
      });
    };

    // ----------------------------------------------------------
    // Category Modal
    // ----------------------------------------------------------
    window.openAddCategoryModal = function() {
      document.getElementById('categoryForm').reset();
      document.getElementById('categoryError').style.display = 'none';
      showModal('categoryModal');
    };

    window.closeCategoryModal = function() {
      hideModal('categoryModal');
    };

    window.addCategory = function(event) {
      event.preventDefault();

      var categoryName = document.getElementById('categoryName').value.trim().toLowerCase();
      if (!categoryName) {
        document.getElementById('categoryError').textContent = 'Numele categoriei este obligatoriu.';
        document.getElementById('categoryError').style.display = 'block';
        return;
      }

      // Validate against known categories
      var validCategories = <%= JSON.stringify(allCats) %>;
      if (!validCategories.includes(categoryName)) {
        document.getElementById('categoryError').textContent = 
          'Categoria "' + categoryName + '" nu este în lista predefinită. Alege una dintre: ' + validCategories.join(', ');
        document.getElementById('categoryError').style.display = 'block';
        return;
      }

      // Check if category already exists in tabs
      var existingTabs = document.querySelectorAll('.category-tab:not(.add-category)');
      var exists = Array.from(existingTabs).some(function(tab) {
        return tab.textContent.toLowerCase().includes(categoryName);
      });

      if (exists) {
        document.getElementById('categoryError').textContent = 
          'Categoria "' + categoryName + '" există deja.';
        document.getElementById('categoryError').style.display = 'block';
        return;
      }

      // Redirect to category filter - this effectively "adds" it by showing it
      // Categories are predefined, so we just navigate
      window.location.href = '?category=' + encodeURIComponent(categoryName);
      return false;
    };

    // ----------------------------------------------------------
    // Close modals on overlay click
    // ----------------------------------------------------------
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('modal-overlay')) {
        e.target.style.display = 'none';
      }
    });

    // ----------------------------------------------------------
    // Close modals on Escape
    // ----------------------------------------------------------
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal-overlay[style*="flex"]').forEach(function(m) {
          m.style.display = 'none';
        });
      }
    });

  })();
</script>