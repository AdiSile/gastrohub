{
  "name": "gastrohub-core",
  "version": "1.0.0",
  "description": "GastroHub - SaaS pentru gestionarea restaurantelor, hotelurilor și serviciilor de catering",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha --recursive tests/ --timeout 10000",
    "test:coverage": "nyc --reporter=html --reporter=text mocha --recursive tests/ --timeout 10000",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "build": "echo 'No build step required'",
    "precommit": "npm run lint && npm test"
  },
  "keywords": [
    "gastrohub",
    "saas",
    "restaurant",
    "management"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "nedb": "^1.8.0",
    "sql.js": "^1.14.1",
    "uuid": "^14.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "mocha": "^8.1.3",
    "nodemon": "^3.0.2",
    "nyc": "^14.1.1",
    "sinon": "^17.0.1",
    "supertest": "^6.3.3"
  }
}
